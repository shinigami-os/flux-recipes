[meta]
name = efivar
version = 38
description = "Library and tool for manipulating EFI variables"
license = LGPL-2.1-or-later
size = 2

[source]
url = https://github.com/rhboot/efivar/releases/download/38/efivar-38.tar.bz2
sha256 = f018ed6e49c5f1c16d336d9fd7687ce87023276591921db1e49a314ad6515349

[deps]
build = gcc make pkgconf
runtime =



[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build
# on_exit() is glibc-only; musl lacks it. The call just frees memory before exit, safe to drop.
sed -i 's/on_exit(free_actions, \&actions);//' src/efisecdb.c
mkdir -p musl-compat/sys
cat > musl-compat/sys/cdefs.h << 'EOF'
#pragma once
#define __BEGIN_DECLS
#define __END_DECLS
#define __THROW
#define __NTH(fct) fct
#define __nonnull(params)
#define __wur
#define __attribute_pure__
#define __attribute_malloc__
#define __attribute_alloc_size__(params)
#define __attribute_warn_unused_result__
#define __always_inline __inline __attribute__((__always_inline__))
#ifndef __WORDSIZE
#define __WORDSIZE 64
#endif
#include <sys/types.h>
#ifndef __off64_t_defined
typedef off_t off64_t;
#define __off64_t_defined
#endif
EOF

%build
unset CROSS_COMPILE
make \
    CROSS_COMPILE="" \
    ARCH=x86_64 \
    LIBDIR=/usr/lib \
    STATIC=1 \
    MARCH=x86-64-v2 \
    HOSTCC=gcc \
    CC="${CC:-gcc} -I$(pwd)/musl-compat" \
    ${AR:+AR=$AR} \
    ${LD:+LD=$LD} \
    ${STRIP:+STRIP=$STRIP}

%post-build

%install
make install DESTDIR="$DESTDIR" \
    ARCH=x86_64 \
    LIBDIR=/usr/lib \
    STATIC=1 \
    CC="${CC:-gcc} -I$(pwd)/musl-compat" \
    ${AR:+AR=$AR}
