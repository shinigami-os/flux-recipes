[meta]
name = greetd
version = 0.10.3.2
description = "Flexible and agnostic login manager daemon"
license = GPL-3.0-only
size = 5

[source]
url = https://github.com/kennylevinsen/greetd/archive/refs/tags/0.10.3.tar.gz
sha256 = ee5cb70e0add4ca9c9fe57e47581ab0002d44c07743fb5492469f3b570db640b

[deps]
build = gcc linux-pam
runtime = linux-pam

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build
mkdir -p .cargo
if [ -n "$FLUX_CROSS_HOST" ]; then
cat > .cargo/config.toml << 'EOF'
[target.x86_64-unknown-linux-musl]
linker = "x86_64-linux-musl-gcc"
EOF
fi

%build
for _h in /home/*; do
    [ -x "$_h/.cargo/bin/cargo" ] && REAL_HOME="$_h" && break
done
export PATH="$PATH:$REAL_HOME/.cargo/bin"
export CARGO_HOME="$REAL_HOME/.cargo"
export RUSTUP_HOME="$REAL_HOME/.rustup"
if [ -n "$FLUX_CROSS_HOST" ]; then
    export CARGO_TARGET_X86_64_UNKNOWN_LINUX_MUSL_LINKER=x86_64-linux-musl-gcc
    export PKG_CONFIG_SYSROOT_DIR="${FLUX_CROSS_SYSROOT}"
    export RUSTFLAGS="-C target-feature=-crt-static"
    cargo build --release --locked --target x86_64-unknown-linux-musl
else
    # musl targets default to fully static linking, but pam-sys just does a
    # plain "cargo:rustc-link-lib=pam" with no dylib hint, and upstream PAM
    # only ships shared libs (no libpam.a) - disable crt-static so it links
    # against the .so instead of demanding a static lib that doesn't exist
    export RUSTFLAGS="-C target-feature=-crt-static"
    cargo build --release --locked
fi

%post-build

%install
if [ -n "$FLUX_CROSS_HOST" ]; then
    BINDIR="target/x86_64-unknown-linux-musl/release"
else
    BINDIR="target/release"
fi
install -Dm755 "$BINDIR/greetd" "$DESTDIR/usr/bin/greetd"
install -Dm755 "$BINDIR/agreety" "$DESTDIR/usr/bin/agreety"
install -dm755 "$DESTDIR/etc/greetd"
install -Dm644 "$FLUX_RECIPE_DIR/files/config.toml" "$DESTDIR/etc/greetd/config.toml"
install -dm755 "$DESTDIR/etc/sv/greetd"
install -Dm755 "$FLUX_RECIPE_DIR/files/greetd/run" "$DESTDIR/etc/sv/greetd/run"
# tty1 runs the DE (above); tty2-6 are plain authenticated shells, each its
# own greetd instance (own config, own control socket) so none of them ever
# fight over a shared vt or shared state
for vt in 2 3 4 5 6; do
    install -Dm644 "$FLUX_RECIPE_DIR/files/config-tty$vt.toml" "$DESTDIR/etc/greetd/config-tty$vt.toml"
    install -Dm755 "$FLUX_RECIPE_DIR/files/greetd-tty$vt/run" "$DESTDIR/etc/sv/greetd-tty$vt/run"
done
install -dm755 "$DESTDIR/etc/pam.d"
printf 'auth\trequired\tpam_unix.so\naccount\trequired\tpam_unix.so\nsession\trequired\tpam_unix.so\n' \
    > "$DESTDIR/etc/pam.d/greetd"

%post-install
grep -q '^greetd:' /etc/group || addgroup -S greetd
grep -q '^greetd:' /etc/passwd || adduser -S -G greetd -s /bin/false -H greetd
mkdir -p /home/greetd
chown greetd:greetd /home/greetd
chmod 755 /home/greetd
# getty-tty1 would otherwise fight greetd for tty1 (same vt, same keyboard
# input) - keep it disabled every time greetd is (re)installed, since a
# manual "rescue shell" edit to that service can silently re-enable it
if [ -d /etc/sv/getty-tty1 ]; then
    touch /etc/sv/getty-tty1/down
    sv down /etc/sv/getty-tty1 2>/dev/null || true
fi
for vt in 2 3 4 5 6; do
    sv up /etc/sv/greetd-tty$vt 2>/dev/null || true
done
# greetd re-execs its own binary via /proc/self/exe for each login attempt;
# an already-running instance left over from before this (re)install still
# points at the old, now-deleted inode, so every login would panic with
# "unable to exec ENOENT" until it's kicked to pick up the fresh one
sv kill /etc/sv/greetd 2>/dev/null || true
for vt in 2 3 4 5 6; do
    sv kill /etc/sv/greetd-tty$vt 2>/dev/null || true
done
