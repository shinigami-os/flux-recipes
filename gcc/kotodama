[meta]
name = gcc
version = 14.2.0.5
description = "The GNU Compiler Collection"
license = GPL-3.0
size = 100
no_sysroot_stage = true

[source]
url = https://ftp.gnu.org/gnu/gcc/gcc-14.2.0/gcc-14.2.0.tar.xz
sha256 = a7b39bc69cbf9e25826c5a60ab26477001f7c08d85cec04bc0e29cabed6f3cc9

[deps]
build = gcc make gmp mpfr mpc zlib
runtime = gmp mpfr mpc zlib gcc-libs

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build
mkdir -p build

%build
cd build
# musl never implements these glibc-only, non-POSIX pthread extensions;
# force them off so libstdc++'s <mutex>/<condition_variable> don't call
# functions that don't exist on the target
export glibcxx_cv_PTHREAD_COND_CLOCKWAIT=no
export glibcxx_cv_PTHREAD_MUTEX_CLOCKLOCK=no
export glibcxx_cv_PTHREAD_RWLOCK_CLOCKLOCK=no
../configure \
  --prefix=/usr \
  --with-sysroot=/ \
  --enable-languages=c,c++ \
  --disable-multilib \
  --disable-bootstrap \
  --with-gmp="${FLUX_CROSS_SYSROOT:-}/usr" \
  --with-mpfr="${FLUX_CROSS_SYSROOT:-}/usr" \
  --with-mpc="${FLUX_CROSS_SYSROOT:-}/usr" \
  --build=$(gcc -dumpmachine) \
  --host=${FLUX_CROSS_HOST:-$(gcc -dumpmachine)} \
  ${FLUX_CROSS_HOST:+CC_FOR_BUILD=gcc} \
  ${FLUX_CROSS_HOST:+CXX_FOR_BUILD=g++} \
  ${CC:+CC=$CC}
make

%post-build

%install
cd build
make DESTDIR=$DESTDIR install
# a properly --host=x86_64-linux-musl cross-compiled target lib is genuinely
# musl-linked; keep it instead of relying on kira-base's much older bundled copies