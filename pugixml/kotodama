[meta]
name = pugixml
version = 1.16.1
description = "Light-weight C++ XML processing library"
license = MIT
size = 1

[source]
url = git+https://github.com/zeux/pugixml#v1.16
sha256 =

[deps]
build = gcc cmake ninja pkgconf
runtime =

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build

%build
cmake -S . -B build -G Ninja \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_INSTALL_LIBDIR=lib \
    -DBUILD_SHARED_LIBS=ON
cmake --build build

%post-build

%install
DESTDIR="$DESTDIR" cmake --install build
