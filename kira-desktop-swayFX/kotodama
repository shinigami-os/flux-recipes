size = 1

[source]

[deps]
build =
runtime = mesa libglvnd xwayland swayfx eww fuzzel pcmanfm-qt mako swaylock-effects swaybg flameshot foot yazi qt6-wayland xdg-desktop-portal-wlr xdg-desktop-portal-gtk playerctl python3 iw nm-connection-editor pipewire wireplumber pavucontrol pamixer brightnessctl libgomp greetd kira-desktop-fonts jq kira-desktop-swayFX-config

[build]
cflags =

%pre-build

%build

%post-build

%install
install -Dm644 "$FLUX_RECIPE_DIR/files/swayFX.desktop-env" "$DESTDIR/usr/share/kira-desktop/swayFX.desktop-env"
install -Dm644 "$FLUX_RECIPE_DIR/files/default.png" "$DESTDIR/usr/share/kira/wallpapers/default.png"

%post-install
