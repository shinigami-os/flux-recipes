[meta]
name = findutils
version = 4.10.0
description = "GNU find, xargs, and locate"
license = GPL-3.0
size = 5

[source]
url = https://ftp.gnu.org/gnu/findutils/findutils-4.10.0.tar.xz
sha256 = 1387e0b67ff247d2abde998f90dfbf70c1491391a59ddfecb8ae698789f0a4f5

[deps]
build = gcc make
runtime =

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build

%build
./configure --prefix=/usr
make

%post-build

%install
make DESTDIR=$DESTDIR install
