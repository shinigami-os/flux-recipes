[meta]
name = neovim
version = 0.12.2
description = "Vim-fork focused on extensibility and usability"
license = Apache-2.0
size = 14

[source]
url = https://github.com/neovim/neovim/archive/refs/tags/nightly.tar.gz
sha256 = c72b4951ffcb9b4a9260beeb95f045fe186da9fdec6c7735bd17648bf73f6a4f

[deps]
build = gcc clang cmake ninja make curl git pkgconf luajit
runtime = luajit

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build

%build
unset DESTDIR
make CMAKE_BUILD_TYPE=Release CMAKE_INSTALL_PREFIX=/usr \
    DEPS_CMAKE_FLAGS="-DLUAJIT_INCLUDE_DIR=/usr/include/luajit-2.1 -DLUAJIT_LIBRARY=/usr/lib/x86_64-linux-gnu/libluajit-5.1.so"

%post-build

%install
make DESTDIR="$DESTDIR" CMAKE_INSTALL_PREFIX=/usr install