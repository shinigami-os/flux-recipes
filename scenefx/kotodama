[meta]
name = scenefx
version = 0.4
description = "Wayland scene graph effects library for wlroots"
license = MIT
size = 2

[source]
url = https://github.com/wlrfx/scenefx/archive/refs/tags/0.4.tar.gz
sha256 = b307a59160933d5d99824ef26c8ad44cf648f1ed18af26c8dc9343d2b2df0f74

[deps]
build = gcc meson ninja pkgconf wayland wayland-protocols wlroots libdrm libxkbcommon pixman
runtime = wayland wlroots libdrm libxkbcommon pixman

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build
cat > native-pkgconfig.sh << 'WRAPPER'
#!/bin/sh
unset PKG_CONFIG_LIBDIR
unset PKG_CONFIG_PATH
exec /usr/bin/pkg-config "$@"
WRAPPER
cat > native-file.ini << EOF
[binaries]
pkg-config = ['sh', '$(pwd)/native-pkgconfig.sh']
wayland-scanner = '/usr/bin/wayland-scanner'
EOF
if [ -n "$FLUX_CROSS_HOST" ]; then
cat > cross-file.ini << EOF
[host_machine]
system = 'linux'
cpu_family = 'x86_64'
cpu = 'x86_64'
endian = 'little'
[binaries]
c = '${CC:-gcc}'
ar = '${AR:-ar}'
strip = '${STRIP:-strip}'
pkg-config = 'pkg-config'
[properties]
sys_root = '${FLUX_CROSS_SYSROOT}'
pkg_config_libdir = ['${FLUX_CROSS_SYSROOT}/usr/lib/pkgconfig', '${FLUX_CROSS_SYSROOT}/usr/share/pkgconfig']
EOF
fi

%build
rm -rf build
meson setup build \
    --native-file=native-file.ini \
    --prefix=/usr \
    --buildtype=release \
    ${FLUX_CROSS_HOST:+--cross-file=cross-file.ini} \
    -Dexamples=false \
    -Drenderers=gles2
ninja -C build

%post-build

%install
DESTDIR="$DESTDIR" ninja -C build install
