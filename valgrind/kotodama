[meta]
name = valgrind
version = 3.25.1
description = "Memory debugging, memory leak detection, and profiling suite"
license = GPL-2.0-or-later
size = 60

[source]
url = https://sourceware.org/pub/valgrind/valgrind-3.25.1.tar.bz2
sha256 = 61deb8d0727b45c268efdc1b3b6c9e679cd97cbf5ee4b28d1dead7c8b7a271af

[deps]
build = gcc make perl
runtime = perl python3

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build

%build
# valgrind's own JIT/instrumentation core needs precise control over binary
# layout, which conflicts with several hardening defaults; mirrors Alpine's
# musl-targeting valgrind build (the same flags they've proven work on musl)
export CFLAGS="$CFLAGS -fno-stack-protector -no-pie -U_FORTIFY_SOURCE"
./configure \
    --prefix=/usr \
    --sysconfdir=/etc \
    --mandir=/usr/share/man \
    --infodir=/usr/share/info \
    --localstatedir=/var \
    --without-mpicc
make

%post-build

%install
make DESTDIR="$DESTDIR" install
