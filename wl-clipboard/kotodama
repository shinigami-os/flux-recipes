[meta]
name = wl-clipboard
version = 2.3.0
description = "Command-line copy/paste utilities for Wayland"
license = GPL-3.0-or-later
size = 1

[source]
url = git+https://github.com/bugaevc/wl-clipboard#v2.3.0
sha256 =

[deps]
build = gcc meson ninja pkgconf wayland wayland-protocols
runtime = wayland

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build

%build
meson setup build --prefix=/usr --buildtype=release
ninja -C build

%post-build

%install
DESTDIR="$DESTDIR" ninja -C build install
