[meta]
name = cairo
version = 1.18.2
description = "2D vector graphics library"
license = LGPL-2.1-or-later OR MPL-1.1
size = 5

[source]
url = https://cairographics.org/releases/cairo-1.18.2.tar.xz
sha256 = a62b9bb42425e844cc3d6ddde043ff39dbabedd1542eba57a2eb79f85889d45a

[deps]
build = gcc meson ninja pkgconf pixman freetype fontconfig glib zlib
runtime = pixman freetype fontconfig glib zlib

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build
sed -i '/#include <freetype\/freetype.h>/a #include <freetype\/ftcolor.h>' src/cairo-ft-private.h
if [ -n "$FLUX_CROSS_HOST" ]; then
cat > cross-file.ini << EOF
[host_machine]
system = 'linux'
cpu_family = 'x86_64'
cpu = 'x86_64'
endian = 'little'
[binaries]
c = '${CC:-gcc}'
ar = '${AR:-ar}'
strip = '${STRIP:-strip}'
pkg-config = 'pkg-config'
[properties]
sys_root = '${FLUX_CROSS_SYSROOT}'
pkg_config_libdir = ['${FLUX_CROSS_SYSROOT}/usr/lib/pkgconfig']
EOF
fi

%build
meson setup build \
    --prefix=/usr \
    --buildtype=release \
    ${FLUX_CROSS_HOST:+--cross-file=cross-file.ini} \
    -Dtests=disabled \
    -Dfreetype=enabled \
    -Dfontconfig=enabled \
    -Dxlib=disabled \
    -Dxcb=disabled \
    -Dpng=disabled \
    -Dspectre=disabled \
    -Dsymbol-lookup=disabled
ninja -C build

%post-build

%install
DESTDIR="$DESTDIR" ninja -C build install
