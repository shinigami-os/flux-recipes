[meta]
name = pavucontrol
version = 6.2
description = "PulseAudio/PipeWire volume control GUI"
license = GPL-2.0-or-later
size = 2

[source]
url = https://freedesktop.org/software/pulseaudio/pavucontrol/pavucontrol-6.2.tar.xz
sha256 = e93a7836c7307dcbc989e95fc7ec0878322514c475fabd90e89ed52fd4f15d32

[deps]
build = gcc meson ninja pkgconf pipewire gtk4 libadwaita gtkmm4
runtime = pipewire gtk4 libadwaita

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build

%build
meson setup build \
    --prefix=/usr \
    --buildtype=release
ninja -C build

%post-build

%install
DESTDIR="$DESTDIR" ninja -C build install
