[meta]
name = glib-networking
version = 2.80.1.1
description = "Network-related GIO modules (TLS support via OpenSSL)"
license = LGPL-2.1-or-later
size = 2

[source]
url = https://download.gnome.org/sources/glib-networking/2.80/glib-networking-2.80.1.tar.xz
sha256 = b80e2874157cd55071f1b6710fa0b911d5ac5de106a9ee2a4c9c7bee61782f8e

[deps]
build = gcc meson ninja pkgconf glib openssl gsettings-desktop-schemas
runtime = glib openssl gsettings-desktop-schemas

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build
# a stale OCSP staple (common with CDN-cached responses, e.g. Flathub) was
# being treated as a hard TLS failure ("Unacceptable TLS certificate"),
# even though the certificate chain itself verifies fine and curl/browsers
# don't hard-fail on this - only skip the freshness check, still honor an
# actual REVOKED/UNKNOWN status from the (stale) response
sed -i '575,582c\      if (!OCSP_check_validity (this_update_time, next_update_time, 300L, -1L)) ERR_clear_error ();' tls/openssl/gtlsdatabase-openssl.c

%build
export CFLAGS="-O2 -pipe -march=x86-64-v2"
meson setup build --prefix=/usr --buildtype=release \
    -Dgnutls=disabled -Dopenssl=enabled -Dlibproxy=disabled -Dinstalled_tests=false
ninja -C build

%post-build

%install
DESTDIR="$DESTDIR" ninja -C build install
