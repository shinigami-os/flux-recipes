[meta]
name = libfm-qt
version = 2.1.0
description = "Qt port of libfm file management library"
license = LGPL-2.1-or-later
size = 3

[source]
url = https://github.com/lxqt/libfm-qt/releases/download/2.1.0/libfm-qt-2.1.0.tar.xz
sha256 = bfa03ee1d8ae9e50f33b31d50a5cb0ffbca5e6d6f5dd3a0df04c8300fc1a29d7

[deps]
build = gcc cmake ninja pkgconf qt6-base glib libexif libmenu-cache lxqt2-build-tools lxqt-menu-data
runtime = qt6-base glib libexif libmenu-cache

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build
sed -i 's/find_package(XCB REQUIRED)/find_package(XCB)/' CMakeLists.txt
sed -i '/xdndworkaround\.cpp/d' src/CMakeLists.txt
perl -0777 -i -pe 's/(\s*\$\{XCB_LIBRARIES\})//g; s/(\s*"\$\{XCB_INCLUDE_DIRS\}")//g' src/CMakeLists.txt
cat > src/xdndworkaround.h << 'STUB'
#pragma once
struct XdndWorkaround { XdndWorkaround() {} };
STUB
mkdir -p src/xcb
cat > src/xcb/xcb.h << 'STUB'
#pragma once
typedef unsigned int xcb_window_t;
typedef unsigned int xcb_atom_t;
typedef unsigned int xcb_timestamp_t;
STUB
if [ -n "$FLUX_CROSS_HOST" ]; then
cat > toolchain.cmake << EOF
set(CMAKE_SYSTEM_NAME Linux)
set(CMAKE_SYSTEM_PROCESSOR x86_64)
set(CMAKE_C_COMPILER ${CC})
set(CMAKE_CXX_COMPILER ${CXX})
set(CMAKE_SYSROOT ${FLUX_CROSS_SYSROOT})
set(CMAKE_FIND_ROOT_PATH ${FLUX_CROSS_SYSROOT})
set(CMAKE_FIND_ROOT_PATH_MODE_PROGRAM NEVER)
set(CMAKE_FIND_ROOT_PATH_MODE_LIBRARY ONLY)
set(CMAKE_FIND_ROOT_PATH_MODE_INCLUDE ONLY)
set(CMAKE_FIND_ROOT_PATH_MODE_PACKAGE ONLY)
EOF
fi

%build
rm -rf build
cmake -S . -B build \
    -GNinja \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DCMAKE_BUILD_TYPE=Release \
    ${FLUX_CROSS_HOST:+-DCMAKE_TOOLCHAIN_FILE=toolchain.cmake} \
    ${FLUX_CROSS_HOST:+-DQT_HOST_PATH=/usr} \
    ${FLUX_CROSS_HOST:+-DQT_HOST_PATH_CMAKE_DIR=/usr/lib/x86_64-linux-gnu/cmake} \
    -DQT_NO_PACKAGE_VERSION_CHECK=TRUE \
    -DBUILD_TESTING=OFF \
    ${FLUX_CROSS_HOST:+-DQt6LinguistTools_DIR=/usr/lib/x86_64-linux-gnu/cmake/Qt6LinguistTools}
cmake --build build

%post-build

%install
DESTDIR="$DESTDIR" cmake --install build
