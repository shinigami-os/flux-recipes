[meta]
name = flameshot
version = 13.3.0
description = "Powerful screenshot tool with annotation support"
license = GPL-3.0-or-later
size = 5

[source]
url = https://github.com/flameshot-org/flameshot/archive/refs/tags/v13.3.0.tar.gz
sha256 = bd1666313c875400e9588b47eb3fd2f4d0828460b3705a215b97746ea654c1b4

[deps]
build = gcc cmake ninja pkgconf qt6-base qt6-svg qt6-wayland
runtime = qt6-base qt6-svg qt6-wayland grim

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build

%build
cmake -S . -B build \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DCMAKE_BUILD_TYPE=Release \
    -DUSE_WAYLAND_CLIPBOARD=false \
    -DUSE_WAYLAND_GRIM=true \
    -DCMAKE_DISABLE_FIND_PACKAGE_zstd=ON \
    -DQT_FEATURE_zstd=OFF \
    ${FLUX_CROSS_HOST:+-DCMAKE_SYSTEM_NAME=Linux} \
    ${FLUX_CROSS_HOST:+-DCMAKE_C_COMPILER=$CC} \
    ${FLUX_CROSS_HOST:+-DCMAKE_CXX_COMPILER=$CXX} \
    ${FLUX_CROSS_HOST:+-DCMAKE_FIND_ROOT_PATH=$FLUX_CROSS_SYSROOT} \
    ${FLUX_CROSS_HOST:+-DCMAKE_FIND_ROOT_PATH_MODE_PROGRAM=NEVER} \
    ${FLUX_CROSS_HOST:+-DCMAKE_FIND_ROOT_PATH_MODE_LIBRARY=ONLY} \
    ${FLUX_CROSS_HOST:+-DCMAKE_FIND_ROOT_PATH_MODE_INCLUDE=ONLY} \
    ${FLUX_CROSS_HOST:+-DQT_HOST_PATH=/usr} \
    ${FLUX_CROSS_HOST:+-DQT_HOST_PATH_CMAKE_DIR=/usr/lib/x86_64-linux-gnu/cmake} \
    -DQT_NO_PACKAGE_VERSION_CHECK=TRUE
cmake --build build

%post-build

%install
DESTDIR="$DESTDIR" cmake --install build
# new users get grim-backed screenshots out of the box on swayFX/Wayland;
# QSettings has no system-wide default for UserScope, so seed it via skel
install -dm755 "$DESTDIR/etc/skel/.config/flameshot"
cat > "$DESTDIR/etc/skel/.config/flameshot/flameshot.ini" << 'EOF'
[General]
useGrimAdapter=true
EOF
