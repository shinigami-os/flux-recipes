[meta]
name = hypridle
version = 0.1.7
description = "Hyprland's idle daemon"
license = BSD-3-Clause
size = 2

[source]
url = git+https://github.com/hyprwm/hypridle#v0.1.7
sha256 =

[deps]
build = gcc cmake ninja pkgconf hyprwayland-scanner hyprlang hyprutils hyprland-protocols sdbus-cpp wayland wayland-protocols
runtime = hyprlang hyprutils sdbus-cpp wayland

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build

%build
cmake -S . -B build -G Ninja \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_INSTALL_LIBDIR=lib
cmake --build build

%post-build

%install
DESTDIR="$DESTDIR" cmake --install build
