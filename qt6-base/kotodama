[meta]
name = qt6-base
version = 6.8.3.1
description = "Qt6 base framework"
license = GPL-3.0-only OR LGPL-3.0-only
size = 120

[source]
url = https://download.qt.io/archive/qt/6.8/6.8.3/submodules/qtbase-everywhere-src-6.8.3.tar.xz
sha256 = 56001b905601bb9023d399f3ba780d7fa940f3e4861e496a7c490331f49e0b80

[deps]
build = gcc cmake ninja pkgconf glib dbus libglvnd mesa libdrm libxkbcommon wayland wayland-protocols zlib zstd freetype harfbuzz
runtime = glib dbus libglvnd libdrm libxkbcommon wayland zlib zstd freetype harfbuzz

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build
# __cxa_call_terminate is missing from Kira's libstdc++ across every gcc
# build so far (confirmed present in gcc's own eh_call.cc source with no
# platform guard - the gap is elsewhere in the build system, not worth
# another gcc rebuild for a code path this rare: it only runs when a
# noexcept destructor itself throws while unwinding). Provide a minimal
# stub that does exactly what the real implementation falls back to anyway.
cat > cxa_call_terminate_shim.cpp << 'EOF'
namespace std { [[noreturn]] void terminate() noexcept; }
extern "C" void __cxa_call_terminate(void*) noexcept {
    std::terminate();
}
EOF
g++ -c -O2 -o cxa_call_terminate_shim.o cxa_call_terminate_shim.cpp
if [ -n "$FLUX_CROSS_HOST" ]; then
cat > toolchain.cmake << EOF
set(CMAKE_SYSTEM_NAME Linux)
set(CMAKE_SYSTEM_PROCESSOR x86_64)
set(CMAKE_C_COMPILER ${CC})
set(CMAKE_CXX_COMPILER ${CXX})
set(CMAKE_SYSROOT ${FLUX_CROSS_SYSROOT})
set(CMAKE_FIND_ROOT_PATH ${FLUX_CROSS_SYSROOT})
set(CMAKE_FIND_ROOT_PATH_MODE_PROGRAM NEVER)
set(CMAKE_FIND_ROOT_PATH_MODE_LIBRARY ONLY)
set(CMAKE_FIND_ROOT_PATH_MODE_INCLUDE ONLY)
set(CMAKE_FIND_ROOT_PATH_MODE_PACKAGE ONLY)
EOF
fi

%build
rm -rf build
cmake -S . -B build \
    -GNinja \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_INSTALL_LIBDIR=lib \
    -DCMAKE_CXX_FLAGS=-U_GLIBCXX_ASSERTIONS \
    -DCMAKE_SHARED_LINKER_FLAGS="$(pwd)/cxa_call_terminate_shim.o" \
    -DCMAKE_EXE_LINKER_FLAGS="$(pwd)/cxa_call_terminate_shim.o" \
    ${FLUX_CROSS_HOST:+-DCMAKE_TOOLCHAIN_FILE=toolchain.cmake} \
    ${FLUX_CROSS_HOST:+-DQT_HOST_PATH=/usr} \
    ${FLUX_CROSS_HOST:+-DQT_HOST_PATH_CMAKE_DIR=/usr/lib/x86_64-linux-gnu/cmake} \
    ${FLUX_CROSS_HOST:+-DQT_NO_PACKAGE_VERSION_CHECK=TRUE} \
    -DQT_BUILD_TESTS=OFF \
    -DQT_BUILD_EXAMPLES=OFF \
    -DFEATURE_xcb=OFF \
    -DFEATURE_dbus=ON \
    -DFEATURE_wayland=ON \
    -DFEATURE_openssl=OFF \
    -DFEATURE_ssl=OFF \
    -DFEATURE_system_zlib=ON \
    -DFEATURE_system_zstd=ON \
    -DFEATURE_system_pcre2=ON \
    -DFEATURE_system_harfbuzz=ON \
    -DFEATURE_system_freetype=ON \
    -DFEATURE_reduce_relocations=OFF
cmake --build build

%post-build

%install
DESTDIR="$DESTDIR" cmake --install build
