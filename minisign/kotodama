[meta]
name = minisign
version = 0.12
description = "Simple tool to sign files and verify signatures"
license = ISC
size = 1

[source]
url = git+https://github.com/jedisct1/minisign#0.12
sha256 =

[deps]
build = gcc cmake ninja pkgconf libsodium
runtime = libsodium

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build

%build
cmake -S . -B build -G Ninja \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_INSTALL_LIBDIR=lib
cmake --build build

%post-build

%install
DESTDIR="$DESTDIR" cmake --install build
