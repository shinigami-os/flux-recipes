[meta]
name = libXfont2
version = 2.0.7
description = "X11 font rasterization library"
license = MIT
size = 1

[source]
url = https://xorg.freedesktop.org/releases/individual/lib/libXfont2-2.0.7.tar.xz
sha256 = 2b3b3dad9347db41dca56beb7db5878f283bde1142f04d9f8e478af435dfdc53

[deps]
build = gcc make pkgconf xorgproto xtrans libXau freetype libfontenc zlib
runtime = freetype libfontenc zlib

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build
if [ -n "$FLUX_CROSS_HOST" ]; then
    export PKG_CONFIG_PATH="${FLUX_CROSS_SYSROOT}/usr/lib/pkgconfig:${FLUX_CROSS_SYSROOT}/usr/share/pkgconfig"
    export PKG_CONFIG_LIBDIR="${FLUX_CROSS_SYSROOT}/usr/lib/pkgconfig:${FLUX_CROSS_SYSROOT}/usr/share/pkgconfig"
fi

%build
./configure \
    --host="${FLUX_CROSS_HOST:-}" \
    --prefix=/usr \
    --disable-static \
    --enable-freetype \
    --disable-devel-docs \
    --without-xmlto \
    --without-fop
make

%install
make DESTDIR="$DESTDIR" install
