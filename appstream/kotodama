[meta]
name = appstream
version = 1.0.5
description = "Tools and libraries to work with AppStream metadata"
license = LGPL-2.1-or-later
size = 4

[source]
url = https://github.com/ximion/appstream/archive/refs/tags/v1.0.5.tar.gz
sha256 = dd33b1375ba4221ffee060e2778c478e8150d7b1108c6309148f5fb1ca6e90c0

[deps]
build = gcc meson ninja pkgconf glib curl libxml2 libyaml zstd
runtime = glib curl libxml2 libyaml zstd

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build
sed -i "/'- Wincompatible-pointer-types-discards-qualifiers'/d" subprojects/libxmlb/meson.build 2>/dev/null || true
sed -i '/Wincompatible-pointer-types-discards-qualifiers/d' subprojects/libxmlb/meson.build 2>/dev/null || true
sed -i "s/ascli_exe = find_program('appstreamcli')/ascli_exe = find_program('appstreamcli', native: true)/" data/meson.build
cat > native-pkgconfig.sh << 'WRAPPER'
#!/bin/sh
unset PKG_CONFIG_LIBDIR
unset PKG_CONFIG_PATH
exec /usr/bin/pkg-config "$@"
WRAPPER
cat > native-file.ini << EOF
[binaries]
pkg-config = ['sh', '$(pwd)/native-pkgconfig.sh']
glib-compile-resources = '/usr/bin/glib-compile-resources'
glib-compile-schemas = '/usr/bin/glib-compile-schemas'
gdbus-codegen = '/usr/bin/gdbus-codegen'
appstreamcli = '/usr/bin/appstreamcli'
[properties]
pkg_config_libdir = ['/usr/lib/x86_64-linux-gnu/pkgconfig', '/usr/lib/pkgconfig', '/usr/share/pkgconfig']
EOF
if [ -n "$FLUX_CROSS_HOST" ]; then
cat > cross-file.ini << EOF
[host_machine]
system = 'linux'
cpu_family = 'x86_64'
cpu = 'x86_64'
endian = 'little'
[binaries]
c = '${CC:-gcc}'
ar = '${AR:-ar}'
strip = '${STRIP:-strip}'
pkg-config = 'pkg-config'
glib-compile-resources = '/usr/bin/glib-compile-resources'
glib-compile-schemas = '/usr/bin/glib-compile-schemas'
gdbus-codegen = '/usr/bin/gdbus-codegen'
[properties]
sys_root = '${FLUX_CROSS_SYSROOT}'
pkg_config_libdir = ['${FLUX_CROSS_SYSROOT}/usr/lib/pkgconfig', '${FLUX_CROSS_SYSROOT}/usr/share/pkgconfig']
EOF
fi

%build
rm -rf build
meson setup build \
    --native-file=native-file.ini \
    --prefix=/usr \
    --buildtype=release \
    ${FLUX_CROSS_HOST:+--cross-file=cross-file.ini} \
    -Dstemming=false \
    -Dapidocs=false \
    -Ddocs=false \
    -Dinstall-docs=false \
    -Dgir=false \
    -Dvapi=false \
    -Dcompose=false \
    -Dqt=false \
    -Dmaintainer=false \
    -Dsystemd=false \
    -Dapt-support=false
ninja -C build

%post-build

%install
DESTDIR="$DESTDIR" ninja -C build install
