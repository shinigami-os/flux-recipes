[meta]
name = fuzzel
version = 1.14.1
description = "Wayland-native application launcher"
license = MIT
size = 1

[source]
url = https://codeberg.org/dnkl/fuzzel/archive/1.14.1.tar.gz
sha256 = c6416786c3a0600b8ad91ed951c43c002a639870c3823b4a60c910442f4ae097

[deps]
build = gcc meson ninja pkgconf wayland wayland-protocols libxkbcommon cairo pango fcft tllist
runtime = wayland libxkbcommon cairo pango

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build

%build
meson setup build \
    --prefix=/usr \
    --buildtype=release \
    -Denable-cairo=enabled \
    -Dpng-backend=none \
    -Dsvg-backend=none
ninja -C build

%post-build

%install
DESTDIR="$DESTDIR" ninja -C build install
