[meta]
name = librsvg
version = 2.62.3
description = "SVG rendering library"
license = LGPL-2.1-or-later
size = 40

[source]
url = git+https://gitlab.gnome.org/GNOME/librsvg#2.62.3
sha256 =

[deps]
build = gcc meson ninja pkgconf cargo-c dav1d cairo pango gdk-pixbuf glib libxml2 freetype harfbuzz
runtime = cairo pango gdk-pixbuf glib libxml2 freetype harfbuzz dav1d

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build
cat > native-pkgconfig.sh << 'WRAPPER'
#!/bin/sh
unset PKG_CONFIG_LIBDIR
unset PKG_CONFIG_PATH
unset PKG_CONFIG_SYSROOT_DIR
exec /usr/bin/pkg-config "$@"
WRAPPER
chmod +x native-pkgconfig.sh
cat > native-file.ini << EOF
[binaries]
pkg-config = ['sh', '$(pwd)/native-pkgconfig.sh']
EOF

%build
for _h in /home/*; do
    [ -x "$_h/.cargo/bin/cargo" ] && REAL_HOME="$_h" && break
done
export PATH="$PATH:$REAL_HOME/.cargo/bin"
export CARGO_HOME="$REAL_HOME/.cargo"
export RUSTUP_HOME="$REAL_HOME/.rustup"
rm -rf build
meson setup build \
    --native-file=native-file.ini \
    --prefix=/usr \
    --buildtype=release \
    -Dtests=false \
    -Dintrospection=disabled \
    -Dvala=disabled \
    -Ddocs=disabled \
    -Dpixbuf-loader=disabled
ninja -C build

%post-build

%install
DESTDIR="$DESTDIR" ninja -C build install
