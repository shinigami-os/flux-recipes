[meta]
name = fuzzel
version = 1.14.1
description = "Wayland-native application launcher"
license = MIT
size = 1

[source]
url = https://codeberg.org/dnkl/fuzzel/archive/1.14.1.tar.gz
sha256 = c6416786c3a0600b8ad91ed951c43c002a639870c3823b4a60c910442f4ae097

[deps]
build = gcc meson ninja pkgconf wayland wayland-protocols libxkbcommon cairo pango fcft tllist
runtime = wayland libxkbcommon cairo pango

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build
cat > native-pkgconfig.sh << 'WRAPPER'
#!/bin/sh
unset PKG_CONFIG_LIBDIR
unset PKG_CONFIG_PATH
exec /usr/bin/pkg-config "$@"
WRAPPER
cat > native-file.ini << EOF
[binaries]
pkg-config = ['sh', '$(pwd)/native-pkgconfig.sh']
wayland-scanner = '/usr/bin/wayland-scanner'
EOF
if [ -n "$FLUX_CROSS_HOST" ]; then
cat > cross-file.ini << EOF
[host_machine]
system = 'linux'
cpu_family = 'x86_64'
cpu = 'x86_64'
endian = 'little'
[binaries]
c = '${CC:-gcc}'
ar = '${AR:-ar}'
strip = '${STRIP:-strip}'
pkg-config = 'pkg-config'
[properties]
sys_root = '${FLUX_CROSS_SYSROOT}'
pkg_config_libdir = ['${FLUX_CROSS_SYSROOT}/usr/lib/pkgconfig', '${FLUX_CROSS_SYSROOT}/usr/share/pkgconfig']
EOF
fi

%build
rm -rf build
meson setup build \
    --native-file=native-file.ini \
    --prefix=/usr \
    --buildtype=release \
    ${FLUX_CROSS_HOST:+--cross-file=cross-file.ini} \
    -Denable-cairo=enabled \
    -Dpng-backend=none \
    -Dsvg-backend=none \
    -Ddocs=disabled
ninja -C build

%post-build

%install
DESTDIR="$DESTDIR" ninja -C build install
