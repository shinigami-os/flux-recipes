[meta]
name = cage
version = 0.2.1.1
description = "Kiosk Wayland compositor for running a single app fullscreen (hosts regreet for greetd)"
license = MIT
size = 1

[source]
url = https://github.com/cage-kiosk/cage/archive/refs/tags/v0.2.1.tar.gz
sha256 = acab0c83175164a788d7b9f89338cbdebdc4f7197aff6fdc267c32f7181234a9

[deps]
build = gcc meson ninja pkgconf wayland wayland-protocols wlroots libxkbcommon
runtime = wayland wlroots libxkbcommon

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build
cat > native-pkgconfig.sh << 'WRAPPER'
#!/bin/sh
unset PKG_CONFIG_LIBDIR
unset PKG_CONFIG_PATH
unset PKG_CONFIG_SYSROOT_DIR
exec /usr/bin/pkg-config "$@"
WRAPPER
cat > native-file.ini << EOF
[binaries]
pkg-config = ['sh', '$(pwd)/native-pkgconfig.sh']
wayland-scanner = '/usr/bin/wayland-scanner'
EOF
# GTK4 clients (regreet included) call gtk_window_fullscreen() immediately
# on window init, which can send xdg_toplevel::set_fullscreen before the
# surface's first commit - cage's handler here calls
# wlr_xdg_toplevel_set_size() unconditionally, which hits an assert in
# wlroots (schedule_configure requires surface->initialized) if that
# request arrives too early. view_position() already applies the same
# fullscreen/maximize geometry safely once the initial commit lands, so
# this handler can just skip acting on a too-early request.
sed -i "s|struct cg_xdg_shell_view \*xdg_shell_view = wl_container_of(listener, xdg_shell_view, request_fullscreen);|&\n\n\tif (!xdg_shell_view->xdg_toplevel->base->initialized) {\n\t\treturn;\n\t}|" xdg_shell.c

if [ -n "$FLUX_CROSS_HOST" ]; then
cat > cross-file.ini << EOF
[host_machine]
system = 'linux'
cpu_family = 'x86_64'
cpu = 'x86_64'
endian = 'little'
[binaries]
c = '${CC:-gcc}'
ar = '${AR:-ar}'
strip = '${STRIP:-strip}'
pkg-config = 'pkg-config'
[properties]
sys_root = '${FLUX_CROSS_SYSROOT}'
pkg_config_libdir = ['${FLUX_CROSS_SYSROOT}/usr/lib/pkgconfig', '${FLUX_CROSS_SYSROOT}/usr/share/pkgconfig']
EOF
fi

%build
rm -rf build
meson setup build \
    --native-file=native-file.ini \
    --prefix=/usr \
    --buildtype=release \
    ${FLUX_CROSS_HOST:+--cross-file=cross-file.ini} \
    -Dman-pages=disabled
ninja -C build

%post-build

%install
DESTDIR="$DESTDIR" ninja -C build install
