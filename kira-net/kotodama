[meta]
name = kira-net
version = 1.4
description = "Networking stack: NetworkManager (internal DHCP, manages wifi+ethernet), iwd, libnl plus their runit services"
license = MIT
size = 1

[source]

[deps]
build =
runtime = networkmanager iwd libnl openssh

[build]
cflags =

%pre-build

%build

%post-build

%install
install -dm755 "$DESTDIR/etc/sv/networkmanager" "$DESTDIR/etc/sv/sshd" "$DESTDIR/etc/sv/iwd"
install -m755 "$FLUX_RECIPE_DIR/files/networkmanager/run" "$DESTDIR/etc/sv/networkmanager/run"
install -m755 "$FLUX_RECIPE_DIR/files/sshd/run" "$DESTDIR/etc/sv/sshd/run"
install -m755 "$FLUX_RECIPE_DIR/files/iwd/run" "$DESTDIR/etc/sv/iwd/run"
install -dm755 "$DESTDIR/etc/sv/networkmanager/log" "$DESTDIR/etc/sv/sshd/log" "$DESTDIR/etc/sv/iwd/log"
install -m755 "$FLUX_RECIPE_DIR/files/networkmanager/log/run" "$DESTDIR/etc/sv/networkmanager/log/run"
install -m755 "$FLUX_RECIPE_DIR/files/sshd/log/run" "$DESTDIR/etc/sv/sshd/log/run"
install -m755 "$FLUX_RECIPE_DIR/files/iwd/log/run" "$DESTDIR/etc/sv/iwd/log/run"

%post-install
# NetworkManager now manages ethernet directly with its own internal DHCP
# client - a leftover dhcpcd service from before would fight it for the
# same interface
if [ -d /etc/sv/dhcpcd ]; then
    # sv down alone only stops the supervised process - runsv itself keeps
    # the supervise/ control fifos open and races rm -rf out from under it
    sv exit /etc/sv/dhcpcd 2>/dev/null || true
    sleep 2
    rm -rf /etc/sv/dhcpcd
fi

grep -q "^sshd:" /etc/passwd || \
    echo "sshd:x:84:84:sshd privilege separation:/var/empty:/sbin/nologin" >> /etc/passwd
grep -q "^sshd:" /etc/group || \
    echo "sshd:x:84:" >> /etc/group
mkdir -p /var/empty
chown root:root /var/empty
chmod 711 /var/empty

# sv up alone doesn't delete a down file, only overrides runsv for the
# current session - clear it for real so a stray down file (however it
# got there) can't silently disable any of these again on the next boot
for svc in networkmanager iwd sshd; do
    rm -f /etc/sv/$svc/down
    sv up /etc/sv/$svc 2>/dev/null || true
done
