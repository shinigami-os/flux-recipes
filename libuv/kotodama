[meta]
name = libuv
version = 1.52.1
description = "Cross-platform asynchronous I/O library"
license = MIT
size = 2

[source]
url = https://github.com/libuv/libuv/archive/refs/tags/v1.52.1.tar.gz
sha256 = 478baf2599bfbc882c355288c9cb6f92e0e7dda435fa04031fa5b607cf3f414c

[deps]
build = gcc make cmake
runtime =

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build
if [ -n "$FLUX_CROSS_HOST" ]; then
cat > toolchain.cmake << EOF
set(CMAKE_SYSTEM_NAME Linux)
set(CMAKE_SYSTEM_PROCESSOR x86_64)
set(CMAKE_C_COMPILER ${CC:-gcc})
set(CMAKE_SYSROOT ${FLUX_CROSS_SYSROOT})
set(CMAKE_FIND_ROOT_PATH ${FLUX_CROSS_SYSROOT})
set(CMAKE_FIND_ROOT_PATH_MODE_PROGRAM NEVER)
set(CMAKE_FIND_ROOT_PATH_MODE_LIBRARY ONLY)
set(CMAKE_FIND_ROOT_PATH_MODE_INCLUDE ONLY)
EOF
fi

%build
cmake -B build \
    ${FLUX_CROSS_HOST:+-DCMAKE_TOOLCHAIN_FILE=$(pwd)/toolchain.cmake} \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DBUILD_TESTING=OFF \
    -DBUILD_SHARED_LIBS=ON
cmake --build build --parallel $(nproc)

%post-build

%install
DESTDIR=$DESTDIR cmake --install build --prefix /usr
