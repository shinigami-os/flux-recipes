[meta]
name = hyprwire
version = 0.3.1
description = "Hyprland IPC wire protocol library"
license = BSD-3-Clause
size = 2

[source]
url = git+https://github.com/hyprwm/hyprwire#v0.3.1
sha256 =

[deps]
build = gcc cmake ninja pkgconf hyprutils libffi
runtime = hyprutils libffi

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build

%build
cmake -S . -B build -G Ninja \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_INSTALL_LIBDIR=lib
cmake --build build

%post-build

%install
DESTDIR="$DESTDIR" cmake --install build
