[meta]
name = sleex
version = 1.35
description = "AxOS Sleex desktop environment (Hyprland + quickshell shell), Kira's runit-adapted fork"
license = GPL-3.0-only
size = 20

[source]
url = git+https://github.com/shinigami-os/Sleex_runit#Adapting-Sleex-to-runit-systems
sha256 = 2689b410e7e99c3cfe635c8bd646a684a9c46a4d

[deps]
build = gcc cmake ninja pkgconf qt6-base qt6-declarative qt6-connectivity qt6-5compat qt6-multimedia quickshell rsync
runtime = hyprland quickshell qt6-base qt6-declarative qt6-wayland qt6-connectivity qt6-5compat qt6-multimedia
optional = matugen hyprlock hypridle wl-clipboard fuzzel foot

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build

%build
cd src/share/sleex
cmake -S . -B build -G Ninja \
    -DCMAKE_BUILD_TYPE=Release \
    -DDISTRIBUTOR="Kira Linux" \
    -DINSTALL_QMLDIR=usr/qml
cmake --build build

%post-build

%install
# executables
install -dm755 "$DESTDIR/usr/bin"
cp -a src/bin/. "$DESTDIR/usr/bin/"
chmod 755 "$DESTDIR/usr/bin/"*
# system config (sleex hyprland lua config + xdg mimeapps)
install -dm755 "$DESTDIR/etc"
cp -a src/etc/. "$DESTDIR/etc/"
# compiled quickshell plugin (CMakeLists sets prefix "/")
( cd src/share/sleex && DESTDIR="$DESTDIR" cmake --install build )
# QML shell runtime tree
install -dm755 "$DESTDIR/usr/share/sleex"
rsync -a \
    --exclude 'build/' \
    --exclude 'CMakeLists.txt' \
    --exclude 'plugins/' \
    --exclude '.qmlls.ini' \
    --exclude '.qt/' \
    src/share/sleex/ "$DESTDIR/usr/share/sleex/"
# wayland session entry
install -Dm644 src/share/wayland-sessions/sleex.desktop \
    "$DESTDIR/usr/share/wayland-sessions/sleex.desktop"
