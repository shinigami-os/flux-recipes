[meta]
name = kira-net
version = 1.1
description = "Networking stack: NetworkManager, dhcpcd, iwd, libnl plus their runit services"
license = MIT
size = 1

[source]

[deps]
build =
runtime = networkmanager dhcpcd iwd libnl openssh

[build]
cflags =

%pre-build

%build

%post-build

%install
install -dm755 "$DESTDIR/etc/sv/networkmanager" "$DESTDIR/etc/sv/dhcpcd" "$DESTDIR/etc/sv/sshd" "$DESTDIR/etc/sv/iwd"
install -m755 "$FLUX_RECIPE_DIR/files/networkmanager/run" "$DESTDIR/etc/sv/networkmanager/run"
install -m755 "$FLUX_RECIPE_DIR/files/dhcpcd/run" "$DESTDIR/etc/sv/dhcpcd/run"
install -m755 "$FLUX_RECIPE_DIR/files/sshd/run" "$DESTDIR/etc/sv/sshd/run"
install -m755 "$FLUX_RECIPE_DIR/files/iwd/run" "$DESTDIR/etc/sv/iwd/run"
install -dm755 "$DESTDIR/etc/sv/networkmanager/log" "$DESTDIR/etc/sv/dhcpcd/log" "$DESTDIR/etc/sv/sshd/log" "$DESTDIR/etc/sv/iwd/log"
install -m755 "$FLUX_RECIPE_DIR/files/networkmanager/log/run" "$DESTDIR/etc/sv/networkmanager/log/run"
install -m755 "$FLUX_RECIPE_DIR/files/dhcpcd/log/run" "$DESTDIR/etc/sv/dhcpcd/log/run"
install -m755 "$FLUX_RECIPE_DIR/files/sshd/log/run" "$DESTDIR/etc/sv/sshd/log/run"
install -m755 "$FLUX_RECIPE_DIR/files/iwd/log/run" "$DESTDIR/etc/sv/iwd/log/run"

%post-install
grep -q "^dhcpcd:" /etc/passwd || \
    echo "dhcpcd:x:83:83:dhcpcd:/var/lib/dhcpcd:/sbin/nologin" >> /etc/passwd
grep -q "^dhcpcd:" /etc/group || \
    echo "dhcpcd:x:83:" >> /etc/group
mkdir -p /var/lib/dhcpcd

grep -q "^sshd:" /etc/passwd || \
    echo "sshd:x:84:84:sshd privilege separation:/var/empty:/sbin/nologin" >> /etc/passwd
grep -q "^sshd:" /etc/group || \
    echo "sshd:x:84:" >> /etc/group
mkdir -p /var/empty
chown root:root /var/empty
chmod 711 /var/empty
