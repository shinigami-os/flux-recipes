[meta]
name = wlroots
version = 0.19.0
description = "Modular Wayland compositor library"
license = MIT
size = 5

[source]
url = https://gitlab.freedesktop.org/wlroots/wlroots/-/releases/0.19.0/downloads/wlroots-0.19.0.tar.gz
sha256 = aefb0fe2633b0aad1d66123b2f41afab004fb625e2a7790492cdd39a805cac91

[deps]
build = gcc meson ninja pkgconf wayland wayland-protocols libxkbcommon libdrm libinput seatd mesa libglvnd pixman libdisplay-info
runtime = wayland libxkbcommon libdrm libinput seatd mesa pixman libdisplay-info

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build
cat > native-pkgconfig.sh << 'WRAPPER'
#!/bin/sh
unset PKG_CONFIG_LIBDIR
unset PKG_CONFIG_PATH
exec /usr/bin/pkg-config "$@"
WRAPPER
SYSROOT="${FLUX_CROSS_SYSROOT:-/usr}"
cat > native-file.ini << EOF
[binaries]
pkg-config = ['sh', '$(pwd)/native-pkgconfig.sh']
wayland-scanner = '/usr/bin/wayland-scanner'
[properties]
pkg_config_libdir = ['/usr/lib/x86_64-linux-gnu/pkgconfig', '/usr/lib/pkgconfig', '/usr/share/pkgconfig', '${SYSROOT}/usr/share/pkgconfig']
EOF
if [ -n "$FLUX_CROSS_HOST" ]; then
cat > cross-file.ini << EOF
[host_machine]
system = 'linux'
cpu_family = 'x86_64'
cpu = 'x86_64'
endian = 'little'
[binaries]
c = '${CC:-gcc}'
ar = '${AR:-ar}'
strip = '${STRIP:-strip}'
pkg-config = 'pkg-config'
[properties]
sys_root = '${FLUX_CROSS_SYSROOT}'
pkg_config_libdir = ['${FLUX_CROSS_SYSROOT}/usr/lib/pkgconfig', '${FLUX_CROSS_SYSROOT}/usr/share/pkgconfig']
EOF
fi

%build
rm -rf build
meson setup build \
    --native-file=native-file.ini \
    --prefix=/usr \
    --buildtype=release \
    ${FLUX_CROSS_HOST:+--cross-file=cross-file.ini} \
    -Dxwayland=disabled \
    -Dexamples=false \
    -Drenderers=gles2 \
    -Dallocators=gbm \
    -Dbackends=drm,libinput
ninja -C build

%post-build

%install
DESTDIR="$DESTDIR" ninja -C build install
