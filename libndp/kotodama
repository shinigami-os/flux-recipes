[meta]
name = libndp
version = 1.9.3
description = "Library for IPv6 Neighbor Discovery Protocol"
license = LGPL-2.1-or-later
size = 1

[source]
url = https://github.com/jpirko/libndp/archive/refs/tags/v1.9.tar.gz
sha256 = e564f5914a6b1b799c3afa64c258824a801c1b79a29e2fe6525b682249c65261

[deps]
build = gcc make pkgconf
runtime =

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build
# gcc 14 errors (not just warns) on passing sockaddr_in6* where sendto()
# expects const struct sockaddr* - add the explicit cast upstream never did
sed -i 's/sendto(sockfd, buf, buflen, flags, &sin6, sizeof(sin6))/sendto(sockfd, buf, buflen, flags, (struct sockaddr *)\&sin6, sizeof(sin6))/' libndp/libndp.c

%build
# no configure script ships in this tarball (a raw git snapshot) and
# autoconf/automake aren't packaged here, so build the one source file
# directly instead of bootstrapping autotools for it - libtool version-info
# 3:0:3 in configure.ac means SONAME libndp.so.0, full version 0.3.0
export CC="${CC:-gcc}"
$CC -O2 -pipe -march=x86-64-v2 -fPIC -D_GNU_SOURCE -Iinclude -c libndp/libndp.c -o libndp.o
$CC -shared -Wl,-soname,libndp.so.0 -o libndp.so.0.3.0 libndp.o

%post-build

%install
install -Dm755 libndp.so.0.3.0 "$DESTDIR/usr/lib/libndp.so.0.3.0"
ln -sf libndp.so.0.3.0 "$DESTDIR/usr/lib/libndp.so.0"
ln -sf libndp.so.0.3.0 "$DESTDIR/usr/lib/libndp.so"
install -Dm644 include/ndp.h "$DESTDIR/usr/include/ndp.h"
install -dm755 "$DESTDIR/usr/lib/pkgconfig"
cat > "$DESTDIR/usr/lib/pkgconfig/libndp.pc" << EOF
prefix=/usr
exec_prefix=\${prefix}
libdir=\${exec_prefix}/lib
includedir=\${prefix}/include

Name: libndp
Description: Neighbour discovery library.
Version: 1.9
Libs: -L\${libdir} -lndp
Cflags: -I\${includedir}
EOF
