[meta]
name = swaybg
version = 1.2.2
description = "Wallpaper tool for Wayland compositors"
license = MIT
size = 1

[source]
url = https://github.com/swaywm/swaybg/releases/download/v1.2.2/swaybg-1.2.2.tar.gz
sha256 = a6652a0060a0bea3c3318d9d03b6dddac34f6aeca01b883eef9e58281f5202a1

[deps]
build = gcc meson ninja pkgconf wayland wayland-protocols cairo gdk-pixbuf
runtime = wayland cairo gdk-pixbuf

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build

%build
meson setup build \
    --prefix=/usr \
    --buildtype=release \
    -Dgdk-pixbuf=enabled
ninja -C build

%post-build

%install
DESTDIR="$DESTDIR" ninja -C build install
