[meta]
name = bubblewrap
version = 0.11.2.1
description = "Unprivileged sandboxing tool, used by Flatpak"
license = LGPL-2.0-or-later
size = 1

[source]
url = https://github.com/containers/bubblewrap/releases/download/v0.11.2/bubblewrap-0.11.2.tar.xz
sha256 = 69abc30005d2186baf7737feacd8da35633b93cf5af38838ecff17c5f8e924f6

[deps]
build = gcc meson ninja pkgconf
runtime =

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build

%build
export CFLAGS="-O2 -pipe -march=x86-64-v2"
# require_userns stays false: bwrap still tries unprivileged user namespaces
# first, only falling back to the setuid path if that's unavailable
meson setup build --prefix=/usr --buildtype=release -Dsupport_setuid=true
ninja -C build

%post-build

%install
DESTDIR="$DESTDIR" ninja -C build install

%post-install
chown root:root /usr/bin/bwrap
chmod u+s /usr/bin/bwrap
