[meta]
name = ninja
version = 1.13.2
description = "Small build system with a focus on speed"
license = Apache-2.0
size = 1

[source]
url = https://github.com/ninja-build/ninja/archive/refs/tags/v1.13.2.tar.gz
sha256 = 974d6b2f4eeefa25625d34da3cb36bdcebe7fbce40f4c16ac0835fd1c0cbae17

[deps]
build = gcc cmake
runtime =

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build

%build
cmake -B build -DCMAKE_BUILD_TYPE=Release -DCMAKE_INSTALL_PREFIX=/usr
cmake --build build --parallel $(nproc)

%post-build

%install
cmake --install build --prefix /usr DESTDIR=$DESTDIR