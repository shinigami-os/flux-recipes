[meta]
name = libadwaita
version = 1.6.3
description = "Building blocks for modern GNOME applications"
license = LGPL-2.1-or-later
size = 5

[source]
url = https://download.gnome.org/sources/libadwaita/1.6/libadwaita-1.6.3.tar.xz
sha256 = c88d4516edd1e0fc61be925f414efc340e149171756064473a082b6ae9a5dc00

[deps]
build = gcc meson ninja pkgconf gtk4 glib curl libfyaml zstd
runtime = gtk4 glib curl libfyaml zstd

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build
cat > native-pkgconfig.sh << 'WRAPPER'
#!/bin/sh
unset PKG_CONFIG_LIBDIR
unset PKG_CONFIG_PATH
exec /usr/bin/pkg-config "$@"
WRAPPER
chmod +x native-pkgconfig.sh
cat > native-file.ini << EOF
[binaries]
pkg-config = ['sh', '$(pwd)/native-pkgconfig.sh']
glib-compile-schemas = '/usr/bin/glib-compile-schemas'
glib-compile-resources = '/usr/bin/glib-compile-resources'
gdbus-codegen = '/usr/bin/gdbus-codegen'
[properties]
pkg_config_libdir = ['/usr/lib/x86_64-linux-gnu/pkgconfig', '/usr/lib/pkgconfig', '/usr/share/pkgconfig']
EOF
if [ -n "$FLUX_CROSS_HOST" ]; then
cat > cross-file.ini << EOF
[host_machine]
system = 'linux'
cpu_family = 'x86_64'
cpu = 'x86_64'
endian = 'little'
[binaries]
c = '${CC:-gcc}'
ar = '${AR:-ar}'
strip = '${STRIP:-strip}'
pkg-config = 'pkg-config'
glib-compile-schemas = '/usr/bin/glib-compile-schemas'
glib-compile-resources = '/usr/bin/glib-compile-resources'
gdbus-codegen = '/usr/bin/gdbus-codegen'
[properties]
sys_root = '${FLUX_CROSS_SYSROOT}'
pkg_config_libdir = ['${FLUX_CROSS_SYSROOT}/usr/lib/pkgconfig', '${FLUX_CROSS_SYSROOT}/usr/share/pkgconfig']
EOF
fi

%build
rm -rf build
meson setup build \
    --native-file=native-file.ini \
    --prefix=/usr \
    --buildtype=release \
    ${FLUX_CROSS_HOST:+--cross-file=cross-file.ini} \
    "-Dc_args=-Dg_variant_builder_init_static=g_variant_builder_init" \
    -Dintrospection=disabled \
    -Dvapi=false \
    -Dgtk_doc=false \
    -Dtests=false \
    -Dexamples=false
ninja -C build

%post-build

%install
DESTDIR="$DESTDIR" ninja -C build install
