[meta]
name = openssl
version = 3.3.2.1
description = "TLS/SSL and crypto library"
license = Apache-2.0
size = 30

[source]
url = https://www.openssl.org/source/openssl-3.3.2.tar.gz
sha256 = 2e8a40b01979afe8be0bbfb3de5dc1c6709fedb46d6c89c10da114ab5fc3d281

[deps]
build = gcc make perl
runtime =

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build

%build
unset CC CXX CPP AR LD STRIP
./Configure linux-x86_64 \
    --prefix=/usr \
    --openssldir=/etc/ssl \
    --libdir=lib \
    --release \
    no-tests \
    ${FLUX_CROSS_SYSROOT:+--sysroot=$FLUX_CROSS_SYSROOT}
make

%post-build

%install
make DESTDIR="$DESTDIR" install_sw install_ssldirs

%post-install
# OpenSSL's own default cert-file lookup (X509_get_default_cert_file)
# expects /etc/ssl/cert.pem; Kira's actual CA bundle lives at
# /etc/ssl/certs/ca-certificates.crt (from kira-base), so anything using
# SSL_CTX_set_default_verify_paths() instead of an explicit CAfile silently
# rejects every certificate without this symlink
if [ -f /etc/ssl/certs/ca-certificates.crt ] && [ ! -e /etc/ssl/cert.pem ]; then
    ln -sf /etc/ssl/certs/ca-certificates.crt /etc/ssl/cert.pem
fi
