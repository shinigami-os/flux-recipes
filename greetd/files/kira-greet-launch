#!/bin/sh
# greetd launches the [default_session] (the greeter itself) directly, with
# no PAM login session opened for it - so unlike a real logged-in session,
# nothing ever sets XDG_RUNTIME_DIR here. The directory itself is prepared
# by etc/sv/greetd/run (as root, before privileges are dropped to us) since
# we can't create it under root-owned /run/user ourselves.
export XDG_RUNTIME_DIR="/run/user/$(id -u)"
# cage inherits tty1 as its controlling terminal from greetd, so its own
# stderr prints straight over the physical screen instead of through
# svlogd - redirect it to a plain file instead so crashes can be inspected
exec >>/home/greetd/greeter.log 2>&1
# regreet's own log file defaults to /var/log/regreet/log, which greetd
# (an unprivileged user) can't create - point it at its own home instead
exec cage -s -- regreet -l /home/greetd/regreet.log
