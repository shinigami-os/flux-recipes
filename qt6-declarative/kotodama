[meta]
name = qt6-declarative
version = 6.8.3
description = "Qt6 Declarative (QML and Qt Quick) framework"
license = GPL-3.0-only OR LGPL-3.0-only
size = 90

[source]
url = https://download.qt.io/archive/qt/6.8/6.8.3/submodules/qtdeclarative-everywhere-src-6.8.3.tar.xz
sha256 = 1f03a2b8f5588b4face7da87926e9b2c1372b3a32157c52df07a75067a9db1af

[deps]
build = gcc cmake ninja pkgconf python3 qt6-base libglvnd mesa
runtime = qt6-base libglvnd mesa

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build
# ios_base_library_init is only ever emitted as a linker alias for
# std::ios_base::Init::Init() when libstdc++ detects GNU symbol versioning
# at its own build time; Qt's <iostream> usage references the alias name
# directly, but Kira's libstdc++ never created it. Provide it ourselves -
# only needs to reach shared libs (that's where the undefined ref lives),
# not executables, so this stays out of CMAKE_EXE_LINKER_FLAGS entirely to
# avoid breaking CMake's own C-only compiler sanity check.
cat > ios_base_library_init_shim.cpp << 'EOF'
#include <ios>
namespace std {
void ios_base_library_init() {
    static ios_base::Init init;
}
}
EOF
g++ -c -O2 -o ios_base_library_init_shim.o ios_base_library_init_shim.cpp

%build
cmake -S . -B build -G Ninja \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_INSTALL_LIBDIR=lib \
    -DCMAKE_CXX_FLAGS=-U_GLIBCXX_ASSERTIONS \
    -DCMAKE_SHARED_LINKER_FLAGS="$(pwd)/ios_base_library_init_shim.o" \
    -DQT_BUILD_TESTS=OFF \
    -DQT_BUILD_EXAMPLES=OFF
cmake --build build

%post-build

%install
DESTDIR="$DESTDIR" cmake --install build
