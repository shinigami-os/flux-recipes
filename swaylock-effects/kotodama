[meta]
name = swaylock-effects
version = 1.6-4
description = "Screen locker for Wayland with blur and effects"
license = MIT
size = 1

[source]
url = https://github.com/mortie/swaylock-effects/archive/refs/tags/v1.6-4.tar.gz
sha256 = 4f82c9d875ce20f1d58227ef65db60aacccb3fb29ce67c0f744849da68e82b20

[deps]
build = gcc meson ninja pkgconf wayland wayland-protocols libxkbcommon cairo pam
runtime = wayland libxkbcommon cairo pam

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build
cat > native-pkgconfig.sh << 'WRAPPER'
#!/bin/sh
unset PKG_CONFIG_LIBDIR
unset PKG_CONFIG_PATH
exec /usr/bin/pkg-config "$@"
WRAPPER
cat > native-file.ini << EOF
[binaries]
pkg-config = ['sh', '$(pwd)/native-pkgconfig.sh']
wayland-scanner = '/usr/bin/wayland-scanner'
EOF

%build
meson setup build \
    --native-file=native-file.ini \
    --prefix=/usr \
    --buildtype=release \
    -Dpam=enabled \
    -Dgdk-pixbuf=disabled \
    -Dman-pages=disabled
ninja -C build

%post-build

%install
DESTDIR="$DESTDIR" ninja -C build install
