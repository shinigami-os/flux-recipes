[meta]
name = netsurf
version = 3.11
description = "Lightweight web browser"
license = GPL-2.0-only
size = 10

[source]
url = https://download.netsurf-browser.org/netsurf/releases/source/netsurf-3.11-src.tar.gz
sha256 = c28a626aefee428d053b13f88b5c440922245976522d12eaf137cfd32d201cb2

[deps]
build = gcc make pkgconf netsurf-buildsystem libutf8proc libnsutils libwapcaplet libparserutils libhubbub libdom libcss libnsgif gtk3 cairo pango libpng libjpeg-turbo curl libressl
runtime = gtk3 cairo pango libpng libjpeg-turbo curl libressl libutf8proc libdom libcss libnsgif libhubbub libparserutils libwapcaplet libnsutils

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build
find content -name '*.c' -exec sed -i 's/defined(LIBRESSL_VERSION_NUMBER) || /!defined(LIBRESSL_VERSION_NUMBER) \&\& /g' {} +

%build
make PREFIX=/usr \
    NSSHARED="${FLUX_CROSS_SYSROOT:-}/usr/share/netsurf-buildsystem" \
    NETSURF_GTK_RESOURCES=/usr/share/netsurf \
    TARGET=gtk3 \
    NETSURF_USE_DUKTAPE=NO \
    ${CC:+CC=$CC} \
    ${AR:+AR=$AR} \
    BUILD_CC=gcc

%post-build

%install
make PREFIX=/usr \
    NSSHARED="${FLUX_CROSS_SYSROOT:-}/usr/share/netsurf-buildsystem" \
    NETSURF_GTK_RESOURCES=/usr/share/netsurf \
    TARGET=gtk3 \
    NETSURF_USE_DUKTAPE=NO \
    ${CC:+CC=$CC} \
    BUILD_CC=gcc \
    DESTDIR=$DESTDIR \
    install
