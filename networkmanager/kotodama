[meta]
name = networkmanager
version = 1.50.0.4
description = "Network connection manager"
license = GPL-2.0-or-later AND LGPL-2.1-or-later
size = 20

[source]
url = https://download.gnome.org/sources/NetworkManager/1.50/NetworkManager-1.50.0.tar.xz
sha256 = fc03e7388a656cebc454c5d89481626122b1975d7c26babc64dc7e488faa66e3

[deps]
build = gcc meson ninja pkgconf glib dbus libnl libndp bluez polkit readline
runtime = glib dbus libnl iwd bluez polkit readline

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build
# bash lives at /usr/bin/bash here, not /bin/bash (no usrmerge)
grep -rl '^#!/bin/bash' tools/ | while read -r f; do sed -i '1s|^#!/bin/bash|#!/usr/bin/bash|' "$f"; done
sed -i "s/xsltproc = find_program('xsltproc')/xsltproc = find_program('xsltproc', required: false)/" meson.build
sed -i "s/value: 'nss', description: 'Cryptography/value: 'null', description: 'Cryptography/" meson_options.txt
sed -i '1s|^|#ifndef NETLINK_GET_STRICT_CHK\n#define NETLINK_GET_STRICT_CHK 12\n#endif\n|' src/libnm-platform/nm-netlink.c
if [ -n "$FLUX_CROSS_HOST" ]; then
cat > cross-file.ini << EOF
[host_machine]
system = 'linux'
cpu_family = 'x86_64'
cpu = 'x86_64'
endian = 'little'
[binaries]
c = '${CC:-gcc}'
ar = '${AR:-ar}'
strip = '${STRIP:-strip}'
pkg-config = 'pkg-config'
[properties]
sys_root = '${FLUX_CROSS_SYSROOT}'
pkg_config_libdir = ['${FLUX_CROSS_SYSROOT}/usr/lib/pkg-config']
EOF
fi

%build
meson setup build \
    --prefix=/usr \
    --sysconfdir=/etc \
    --localstatedir=/var \
    --buildtype=release \
    ${FLUX_CROSS_HOST:+--cross-file=cross-file.ini} \
    -Dintrospection=false \
    -Dvapi=false \
    -Ddocs=false \
    -Dtests=no \
    -Dnetconfig=no \
    -Dselinux=false \
    -Dsystemdsystemunitdir=no \
    -Dsystemd_journal=false \
    -Dsession_tracking=no \
    -Dsuspend_resume=consolekit \
    -Dlibaudit=no \
    -Dppp=false \
    -Dlibpsl=false \
    -Dpolkit=true \
    -Ddhcpcd=no \
    -Ddhcpcanon=no \
    -Dwifi=true \
    -Diwd=true \
    -Dconfig_wifi_backend_default=iwd \
    -Dbluez5_dun=true \
    -Dteamdctl=false \
    -Dmodem_manager=false \
    -Dovs=false \
    -Dnmtui=false \
    -Dnm_cloud_setup=false \
    -Dqt=false \
    -Debpf=false \
    -Dconcheck=false \
    -Dofono=false \
    -Dfirewalld_zone=false \
    -Dmore_logging=false \
    -Dld_gc=false \
    -Dsession_tracking_consolekit=false \
    -Dwext=false \
    -Dnmcli=true \
    -Dreadline=libreadline
ninja -C build

%post-build

%install
DESTDIR="$DESTDIR" ninja -C build install
install -Dm644 "$FLUX_RECIPE_DIR/files/NetworkManager.conf" "$DESTDIR/etc/NetworkManager/NetworkManager.conf"
install -dm755 "$DESTDIR/etc/sv/networkmanager"
install -Dm755 "$FLUX_RECIPE_DIR/files/networkmanager/run" "$DESTDIR/etc/sv/networkmanager/run"

%post-install
# sv up only overrides runsv for the current session - it does not delete
# a down file, so a stray one (however it got there) would silently put
# the service back to "normally down" on every future boot
rm -f /etc/sv/networkmanager/down
sv up /etc/sv/networkmanager 2>/dev/null || true
