[meta]
name = scdoc
version = 1.11.3
description = "Simple man page generator"
license = MIT
size = 1

[source]
url = https://git.sr.ht/~sircmpwn/scdoc/archive/1.11.3.tar.gz
sha256 = 4c5c6136540384e5455b250f768e7ca11b03fdba1a8efc2341ee0f1111e57612

[deps]
build = gcc make
runtime =

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build

%build
make \
    CC="${CC:-gcc}" \
    CFLAGS="${CFLAGS}" \
    PREFIX=/usr

%post-build

%install
make PREFIX=/usr DESTDIR="$DESTDIR" install
