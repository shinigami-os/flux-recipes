[meta]
name = iwlwifi-firmware
version = 2026-07-02
description = "Intel WiFi (iwlwifi) firmware blobs"
license = Intel-iwlwifi-firmware
size = 50

[source]
url = git+https://git.kernel.org/pub/scm/linux/kernel/git/iwlwifi/linux-firmware.git#iwlwifi-fw-2026-07-02
sha256 = 2ab4ce216003ee2c2396c69e19455e4379b0e1f0

[deps]
build = git
runtime =

[build]
cflags =

%pre-build

%build

%post-build

%install
install -dm755 "$DESTDIR/lib/firmware"
cp intel/iwlwifi/iwlwifi-*.ucode "$DESTDIR/lib/firmware/"
install -dm755 "$DESTDIR/usr/share/licenses/iwlwifi-firmware"
cp LICENSES/LICENCE.iwlwifi_firmware "$DESTDIR/usr/share/licenses/iwlwifi-firmware/"

%post-install
echo "[iwlwifi-firmware] Firmware installed. On a running system, reload the driver:"
echo "  modprobe -r iwlwifi && modprobe iwlwifi"
echo "Or reboot."
