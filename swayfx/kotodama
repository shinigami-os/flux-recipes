[meta]
name = swayfx
version = 0.5.2
description = "SwayFX: a glamorous Sway fork with eye candy"
license = MIT
size = 20

[source]
url = https://github.com/WillPower3309/swayfx/archive/refs/tags/0.5.2.tar.gz
sha256 = 075e1a9577f96a71154c61997355dce569816fff05a2c535ec15b252a9acbbe1

[deps]
build = gcc meson ninja pkgconf wayland wayland-protocols libxkbcommon cairo pango json-c libinput libdrm seatd basu wlroots scenefx
runtime = wayland libxkbcommon cairo pango json-c libinput basu wlroots scenefx

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build
cat > native-pkgconfig.sh << 'WRAPPER'
#!/bin/sh
unset PKG_CONFIG_LIBDIR
unset PKG_CONFIG_PATH
unset PKG_CONFIG_SYSROOT_DIR
exec /usr/bin/pkg-config "$@"
WRAPPER
cat > native-file.ini << EOF
[binaries]
pkg-config = ['sh', '$(pwd)/native-pkgconfig.sh']
wayland-scanner = '/usr/bin/wayland-scanner'
EOF
if [ -n "$FLUX_CROSS_HOST" ]; then
cat > cross-file.ini << EOF
[host_machine]
system = 'linux'
cpu_family = 'x86_64'
cpu = 'x86_64'
endian = 'little'
[binaries]
c = '${CC:-gcc}'
ar = '${AR:-ar}'
strip = '${STRIP:-strip}'
pkg-config = 'pkg-config'
[properties]
sys_root = '${FLUX_CROSS_SYSROOT}'
pkg_config_libdir = ['${FLUX_CROSS_SYSROOT}/usr/lib/pkgconfig', '${FLUX_CROSS_SYSROOT}/usr/share/pkgconfig']
EOF
fi

%build
rm -rf build
meson setup build \
    --native-file=native-file.ini \
    --prefix=/usr \
    --buildtype=release \
    ${FLUX_CROSS_HOST:+--cross-file=cross-file.ini} \
    -Dwerror=false \
    -Dtray=disabled \
    -Dsd-bus-provider=basu \
    -Dman-pages=disabled
ninja -C build

%post-build

%install
DESTDIR="$DESTDIR" ninja -C build install
# SwayFX installs itself as plain "sway"; the greeter entry Kira ships is
# swayfx.desktop, so drop the upstream one rather than list the DE twice
rm -f "$DESTDIR/usr/share/wayland-sessions/sway.desktop"
