[meta]
name = tomlplusplus
version = 3.4.0.2
description = "Header-only TOML config file parser and serializer for C++"
license = MIT
size = 1

[source]
url = git+https://github.com/marzer/tomlplusplus#v3.4.0
sha256 =

[deps]
build = gcc cmake ninja pkgconf meson
runtime =

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build

%build
cmake -S . -B build -G Ninja \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_INSTALL_LIBDIR=lib
cmake --build build

%post-build

%install
DESTDIR="$DESTDIR" cmake --install build
# tomlplusplus's own CMake build only installs CMake package-config files,
# never a pkg-config .pc - consumers that use pkg_check_modules() (like
# hyprcursor) need one, so provide it ourselves
install -dm755 "$DESTDIR/usr/lib/pkgconfig"
cat > "$DESTDIR/usr/lib/pkgconfig/tomlplusplus.pc" << 'EOF'
prefix=/usr
includedir=${prefix}/include

Name: tomlplusplus
Description: Header-only TOML config file parser and serializer for C++17
Version: 3.4.0
Cflags: -I${includedir}
EOF
