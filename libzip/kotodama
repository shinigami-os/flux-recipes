[meta]
name = libzip
version = 1.11.4
description = "Library for reading, creating, and modifying zip archives"
license = BSD-3-Clause
size = 2

[source]
url = git+https://github.com/nih-at/libzip#v1.11.4
sha256 =

[deps]
build = gcc cmake ninja pkgconf zlib
runtime = zlib

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build

%build
cmake -S . -B build -G Ninja \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_INSTALL_LIBDIR=lib \
    -DENABLE_COMMONCRYPTO=OFF \
    -DENABLE_GNUTLS=OFF \
    -DENABLE_MBEDTLS=OFF \
    -DENABLE_OPENSSL=OFF \
    -DENABLE_BZIP2=OFF \
    -DENABLE_LZMA=OFF \
    -DENABLE_ZSTD=OFF \
    -DBUILD_TOOLS=OFF \
    -DBUILD_REGRESS=OFF \
    -DBUILD_EXAMPLES=OFF \
    -DBUILD_DOC=OFF
cmake --build build

%post-build

%install
DESTDIR="$DESTDIR" cmake --install build
