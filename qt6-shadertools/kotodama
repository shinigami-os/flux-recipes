[meta]
name = qt6-shadertools
version = 6.11.1
description = "Qt6 Shader Tools (qsb shader baking tool, needed for Qt Quick)"
license = GPL-3.0-only OR LGPL-3.0-only
size = 10

[source]
url = git+https://github.com/qt/qtshadertools#v6.11.1
sha256 =

[deps]
build = gcc cmake ninja pkgconf qt6-base
runtime = qt6-base

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build

%build
cmake -S . -B build -G Ninja \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_INSTALL_LIBDIR=lib \
    -DCMAKE_CXX_FLAGS=-U_GLIBCXX_ASSERTIONS \
    -DQT_BUILD_TESTS=OFF \
    -DQT_BUILD_EXAMPLES=OFF
cmake --build build

%post-build

%install
DESTDIR="$DESTDIR" cmake --install build
