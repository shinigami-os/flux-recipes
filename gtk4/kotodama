[meta]
name = gtk4
version = 4.16.12
description = "GTK 4 widget toolkit"
license = LGPL-2.1-or-later
size = 60

[source]
url = https://download.gnome.org/sources/gtk/4.16/gtk-4.16.12.tar.xz
sha256 = ef31bdbd6f082c4401634a20c850b0050c9bf252ef1e079764ee95a2a0c4c95a

[deps]
build = gcc meson ninja pkgconf glib pango cairo gdk-pixbuf graphene libxkbcommon wayland wayland-protocols libepoxy
runtime = glib pango cairo gdk-pixbuf graphene libxkbcommon wayland libepoxy

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build
cat > native-pkgconfig.sh << 'WRAPPER'
#!/bin/sh
unset PKG_CONFIG_LIBDIR
unset PKG_CONFIG_PATH
unset PKG_CONFIG_SYSROOT_DIR
exec /usr/bin/pkg-config "$@"
WRAPPER
cat > native-file.ini << EOF
[binaries]
pkg-config = ['sh', '$(pwd)/native-pkgconfig.sh']
wayland-scanner = '/usr/bin/wayland-scanner'
glib-compile-schemas = '/usr/bin/glib-compile-schemas'
glib-compile-resources = '/usr/bin/glib-compile-resources'
gdbus-codegen = '/usr/bin/gdbus-codegen'
EOF
if [ -n "$FLUX_CROSS_HOST" ]; then
cat > cross-file.ini << EOF
[host_machine]
system = 'linux'
cpu_family = 'x86_64'
cpu = 'x86_64'
endian = 'little'
[binaries]
c = '${CC:-gcc}'
ar = '${AR:-ar}'
strip = '${STRIP:-strip}'
pkg-config = 'pkg-config'
glib-compile-schemas = '/usr/bin/glib-compile-schemas'
glib-compile-resources = '/usr/bin/glib-compile-resources'
gdbus-codegen = '/usr/bin/gdbus-codegen'
[properties]
sys_root = '${FLUX_CROSS_SYSROOT}'
pkg_config_libdir = ['${FLUX_CROSS_SYSROOT}/usr/lib/pkgconfig', '${FLUX_CROSS_SYSROOT}/usr/share/pkgconfig']
EOF
fi

%build
rm -rf build
meson setup build \
    --native-file=native-file.ini \
    --prefix=/usr \
    --buildtype=release \
    ${FLUX_CROSS_HOST:+--cross-file=cross-file.ini} \
    "-Dc_args=-Dg_variant_builder_init_static=g_variant_builder_init" \
    -Dx11-backend=false \
    -Dwayland-backend=true \
    -Dbroadway-backend=false \
    -Dvulkan=disabled \
    -Dintrospection=disabled \
    -Dbuild-demos=false \
    -Dbuild-examples=false \
    -Dbuild-tests=false \
    -Dbuild-testsuite=false \
    -Dmedia-gstreamer=disabled \
    -Dman-pages=false \
    -Ddocumentation=false
ninja -C build

%post-build

%install
DESTDIR="$DESTDIR" ninja -C build install
