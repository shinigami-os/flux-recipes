[meta]
name = xdg-desktop-portal-hyprland
version = 1.3.12
description = "xdg-desktop-portal backend for Hyprland"
license = BSD-3-Clause
size = 4

[source]
url = git+https://github.com/hyprwm/xdg-desktop-portal-hyprland#v1.3.12
sha256 =

[deps]
build = gcc cmake ninja pkgconf hyprwayland-scanner hyprland-protocols hyprlang hyprutils sdbus-cpp qt6-base pipewire wayland wayland-protocols libdrm mesa xdg-desktop-portal
runtime = hyprlang hyprutils sdbus-cpp qt6-base pipewire wayland libdrm mesa xdg-desktop-portal

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build

%build
cmake -S . -B build -G Ninja \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_INSTALL_LIBDIR=lib
cmake --build build

%post-build

%install
DESTDIR="$DESTDIR" cmake --install build
