[meta]
name = lz4
version = 1.10.0.1
description = "Extremely fast compression algorithm"
license = BSD-2-Clause
size = 3

[source]
url = git+https://github.com/lz4/lz4#v1.10.0
sha256 =

[deps]
build = gcc make pkgconf
runtime =

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build

%build
# lz4's Makefile doesn't add -fPIC on its own; without it the static
# liblz4.a can't be linked into a musl static-pie rust binary (relocation
# R_X86_64_32S needs PIE-safe code)
make -C lib CFLAGS="-O2 -pipe -march=x86-64-v2 -fPIC"

%post-build

%install
make -C lib install PREFIX=/usr DESTDIR="$DESTDIR"
