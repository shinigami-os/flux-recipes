[meta]
name = msgpack-c
version = 6.1.0
description = "MessagePack C implementation"
license = BSL-1.0
size = 1

[source]
url = https://github.com/msgpack/msgpack-c/releases/download/c-6.1.0/msgpack-c-6.1.0.tar.gz
sha256 = 674119f1a85b5f2ecc4c7d5c2859edf50c0b05e0c10aa0df85eefa2c8c14b796

[deps]
build = gcc make cmake
runtime =

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build
if [ -n "$FLUX_CROSS_HOST" ]; then
cat > toolchain.cmake << EOF
set(CMAKE_SYSTEM_NAME Linux)
set(CMAKE_SYSTEM_PROCESSOR x86_64)
set(CMAKE_C_COMPILER ${CC:-gcc})
set(CMAKE_SYSROOT ${FLUX_CROSS_SYSROOT})
set(CMAKE_FIND_ROOT_PATH ${FLUX_CROSS_SYSROOT})
set(CMAKE_FIND_ROOT_PATH_MODE_PROGRAM NEVER)
set(CMAKE_FIND_ROOT_PATH_MODE_LIBRARY ONLY)
set(CMAKE_FIND_ROOT_PATH_MODE_INCLUDE ONLY)
EOF
fi

%build
cmake -B build \
    ${FLUX_CROSS_HOST:+-DCMAKE_TOOLCHAIN_FILE=$(pwd)/toolchain.cmake} \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DMSGPACK_BUILD_TESTS=OFF \
    -DMSGPACK_BUILD_EXAMPLES=OFF \
    -DMSGPACK_ENABLE_SHARED=ON \
    -DMSGPACK_ENABLE_STATIC=ON
cmake --build build --parallel $(nproc)

%post-build

%install
DESTDIR=$DESTDIR cmake --install build --prefix /usr
