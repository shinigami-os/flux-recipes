[meta]
name = swayidle
version = 1.8.0
description = "Idle management daemon for Wayland compositors"
license = MIT
size = 1

[source]
url = https://github.com/swaywm/swayidle/archive/refs/tags/1.8.0.tar.gz
sha256 = 0fba74c520a2bd64acd00bc3bce7bc8c7b84a2609c0f66329d72dfb33cca03d7

[deps]
build = gcc meson ninja pkgconf wayland wayland-protocols elogind
runtime = wayland elogind

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build
if [ -n "$FLUX_CROSS_HOST" ]; then
cat > cross-file.ini << EOF
[host_machine]
system = 'linux'
cpu_family = 'x86_64'
cpu = 'x86_64'
endian = 'little'
[binaries]
c = '${CC:-gcc}'
ar = '${AR:-ar}'
strip = '${STRIP:-strip}'
pkg-config = 'pkg-config'
[properties]
sys_root = '${FLUX_CROSS_SYSROOT}'
pkg_config_libdir = ['${FLUX_CROSS_SYSROOT}/usr/lib/pkgconfig']
EOF
fi

%build
meson setup build \
    --prefix=/usr \
    --buildtype=release \
    ${FLUX_CROSS_HOST:+--cross-file=cross-file.ini} \
    -Dman-pages=disabled \
    -Dlogind=enabled \
    -Dlogind-provider=elogind \
    -Dzsh-completions=false \
    -Dbash-completions=false \
    -Dfish-completions=false
ninja -C build

%install
DESTDIR="$DESTDIR" ninja -C build install
