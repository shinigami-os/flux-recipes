[meta]
name = grub
version = 2.12
description = "GNU GRUB2 bootloader with BIOS (i386-pc) and UEFI (x86_64-efi) targets"
license = GPL-3.0-or-later
size = 90

[source]
url = https://ftp.gnu.org/gnu/grub/grub-2.12.tar.xz
sha256 = f3c97391f7c4eaa677a78e090c7e97e6dc47b16f655f04683ebd37bef7fe0faa

[deps]
build = gcc make python3 flex bison texinfo gettext binutils gawk
runtime = bash

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build
rm -rf build-bios build-efi

%build
unset CFLAGS CXXFLAGS LDFLAGS
export AWK=gawk
_srcdir="$(pwd -P)"

# Both targets built out-of-tree. extra_deps.lst must exist in the source tree
# before make descends into grub-core (it references $(top_srcdir)/grub-core/extra_deps.lst).
touch grub-core/extra_deps.lst

mkdir -p build-bios
cd build-bios
"$_srcdir/configure" \
    --prefix=/usr \
    --sbindir=/usr/bin \
    --sysconfdir=/etc \
    --localstatedir=/var \
    --disable-werror \
    --disable-grub-mkfont \
    --disable-grub-themes \
    --with-platform=pc \
    --target=i386 \
    ${FLUX_CROSS_HOST:+--build=$(gcc -dumpmachine)} \
    ${FLUX_CROSS_HOST:+--host=$FLUX_CROSS_HOST} \
    ${FLUX_CROSS_HOST:+BUILD_CC=gcc}
make
cd ..

mkdir -p build-efi
cd build-efi
"$_srcdir/configure" \
    --prefix=/usr \
    --sbindir=/usr/bin \
    --sysconfdir=/etc \
    --localstatedir=/var \
    --disable-werror \
    --disable-grub-mkfont \
    --disable-grub-themes \
    --with-platform=efi \
    --target=x86_64 \
    ${FLUX_CROSS_HOST:+--build=$(gcc -dumpmachine)} \
    ${FLUX_CROSS_HOST:+--host=$FLUX_CROSS_HOST} \
    ${FLUX_CROSS_HOST:+BUILD_CC=gcc}
make
cd ..

%post-build

%install
cd build-bios
make DESTDIR="$DESTDIR" install
cd ..

cd build-efi
make DESTDIR="$DESTDIR" install
cd ..

# Install grub.cfg placeholder
mkdir -p "$DESTDIR/boot/grub"