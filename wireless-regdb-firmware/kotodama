%pre-build

%build

%post-build

%install
# regulatory.db/.p7s ship pre-built and pre-signed by upstream's own key,
# the one CONFIG_CFG80211_USE_KERNEL_REGDB_KEYS already trusts - regenerating
# either file here would produce a self-signed pair that fails verification
install -dm755 "$DESTDIR/lib/firmware"
install -Dm644 regulatory.db "$DESTDIR/lib/firmware/regulatory.db"
install -Dm644 regulatory.db.p7s "$DESTDIR/lib/firmware/regulatory.db.p7s"
