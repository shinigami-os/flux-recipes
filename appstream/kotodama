[meta]
name = appstream
version = 1.1.2
description = "Tools and libraries to work with AppStream metadata"
license = LGPL-2.1-or-later
size = 4

[source]
url = https://github.com/ximion/appstream/archive/refs/tags/v1.1.2.tar.gz
sha256 = 564ec87b16e9e4ee81fb021e612250fd27f3a3ecd31c209a5dd1ff59def3022d

[deps]
build = gcc meson ninja pkgconf glib curl libxml2 libfyaml zstd
runtime = glib curl libxml2 libfyaml zstd

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build
cat > native-pkgconfig.sh << 'WRAPPER'
#!/bin/sh
unset PKG_CONFIG_LIBDIR
unset PKG_CONFIG_PATH
exec /usr/bin/pkg-config "$@"
WRAPPER
cat > native-file.ini << EOF
[binaries]
pkg-config = ['sh', '$(pwd)/native-pkgconfig.sh']
[properties]
pkg_config_libdir = ['/usr/lib/x86_64-linux-gnu/pkgconfig', '/usr/lib/pkgconfig', '/usr/share/pkgconfig']
EOF
if [ -n "$FLUX_CROSS_HOST" ]; then
cat > cross-file.ini << EOF
[host_machine]
system = 'linux'
cpu_family = 'x86_64'
cpu = 'x86_64'
endian = 'little'
[binaries]
c = '${CC:-gcc}'
ar = '${AR:-ar}'
strip = '${STRIP:-strip}'
pkg-config = 'pkg-config'
[properties]
sys_root = '${FLUX_CROSS_SYSROOT}'
pkg_config_libdir = ['${FLUX_CROSS_SYSROOT}/usr/lib/pkgconfig', '${FLUX_CROSS_SYSROOT}/usr/share/pkgconfig']
EOF
fi

%build
rm -rf build
meson setup build \
    --native-file=native-file.ini \
    --prefix=/usr \
    --buildtype=release \
    ${FLUX_CROSS_HOST:+--cross-file=cross-file.ini} \
    -Dstemming=false \
    -Dapidocs=false \
    -Ddocs=false \
    -Dinstall-docs=false \
    -Dintrospection=false \
    -Dvapi=false \
    -Dcompose=false \
    -Dqt=false \
    -Dtests=false \
    -Dmaintainer=false
ninja -C build

%post-build

%install
DESTDIR="$DESTDIR" ninja -C build install
