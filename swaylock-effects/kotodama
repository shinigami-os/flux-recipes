[meta]
name = swaylock-effects
version = 1.8.5
description = "Screen locker for Wayland compositors (ext-session-lock-v1)"
license = MIT
size = 1

[source]
url = https://github.com/swaywm/swaylock/archive/refs/tags/v1.8.5.tar.gz
sha256 = a13f9de319f3a498b89a027fd46a93310505615956dfb4b40b5cfdb986fb6b58

[deps]
build = gcc meson ninja pkgconf wayland wayland-protocols libxkbcommon cairo linux-pam
runtime = wayland libxkbcommon cairo linux-pam

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build
cat > native-pkgconfig.sh << 'WRAPPER'
#!/bin/sh
unset PKG_CONFIG_LIBDIR
unset PKG_CONFIG_PATH
unset PKG_CONFIG_SYSROOT_DIR
exec /usr/bin/pkg-config "$@"
WRAPPER
cat > native-file.ini << EOF
[binaries]
pkg-config = ['sh', '$(pwd)/native-pkgconfig.sh']
wayland-scanner = '/usr/bin/wayland-scanner'
EOF
if [ -n "$FLUX_CROSS_HOST" ]; then
cat > cross-file.ini << EOF
[host_machine]
system = 'linux'
cpu_family = 'x86_64'
cpu = 'x86_64'
endian = 'little'
[binaries]
c = '${CC:-gcc}'
ar = '${AR:-ar}'
strip = '${STRIP:-strip}'
pkg-config = 'pkg-config'
[properties]
sys_root = '${FLUX_CROSS_SYSROOT}'
pkg_config_libdir = ['${FLUX_CROSS_SYSROOT}/usr/lib/pkgconfig', '${FLUX_CROSS_SYSROOT}/usr/share/pkgconfig']
EOF
fi

%build
rm -rf build
meson setup build \
    --native-file=native-file.ini \
    --prefix=/usr \
    --buildtype=release \
    ${FLUX_CROSS_HOST:+--cross-file=cross-file.ini} \
    -Dpam=enabled \
    -Dgdk-pixbuf=disabled \
    -Dman-pages=disabled
ninja -C build

%post-build

%install
DESTDIR="$DESTDIR" ninja -C build install
