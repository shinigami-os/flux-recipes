[meta]
name = libXcursor
version = 1.2.3
description = "X cursor management library"
license = MIT
size = 1

[source]
url = https://www.x.org/releases/individual/lib/libXcursor-1.2.3.tar.xz
sha256 = fde9402dd4cfe79da71e2d96bb980afc5e6ff4f8a7d74c159e1966afb2b2c2c0

[deps]
build = gcc make pkgconf util-macros xorgproto libX11 libXrender libXfixes
runtime = libX11 libXrender libXfixes

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build

%build
./configure --prefix=/usr
make

%post-build

%install
make DESTDIR="$DESTDIR" install
