[meta]
name = gnome-desktop
version = 44.3
description = "GNOME desktop library"
license = LGPL-2.1-or-later
size = 2

[source]
url = https://download.gnome.org/sources/gnome-desktop/44/gnome-desktop-44.3.tar.xz
sha256 = 40efa9aa8d50effed9227a3d70671e32e9dc35e20f331cab3b562975978f4f8d

[deps]
build = gcc meson ninja pkgconf glib gtk3 gtk4 gsettings-desktop-schemas xkeyboard-config fontconfig iso-codes
runtime = glib gtk3 gtk4 gsettings-desktop-schemas fontconfig

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build
cat > native-pkgconfig.sh << 'WRAPPER'
#!/bin/sh
unset PKG_CONFIG_LIBDIR
unset PKG_CONFIG_PATH
exec /usr/bin/pkg-config "$@"
WRAPPER
cat > native-file.ini << EOF
[binaries]
pkg-config = ['sh', '$(pwd)/native-pkgconfig.sh']
glib-compile-schemas = '/usr/bin/glib-compile-schemas'
gdbus-codegen = '/usr/bin/gdbus-codegen'
glib-compile-resources = '/usr/bin/glib-compile-resources'
EOF
if [ -n "$FLUX_CROSS_HOST" ]; then
cat > cross-file.ini << EOF
[host_machine]
system = 'linux'
cpu_family = 'x86_64'
cpu = 'x86_64'
endian = 'little'
[binaries]
c = '${CC:-gcc}'
ar = '${AR:-ar}'
strip = '${STRIP:-strip}'
pkg-config = 'pkg-config'
glib-compile-schemas = '/usr/bin/glib-compile-schemas'
gdbus-codegen = '/usr/bin/gdbus-codegen'
glib-compile-resources = '/usr/bin/glib-compile-resources'
[properties]
sys_root = '${FLUX_CROSS_SYSROOT}'
pkg_config_libdir = ['${FLUX_CROSS_SYSROOT}/usr/lib/pkgconfig', '${FLUX_CROSS_SYSROOT}/usr/share/pkgconfig']
EOF
fi

%build
rm -rf build
meson setup build \
    --native-file=native-file.ini \
    --prefix=/usr \
    --buildtype=release \
    ${FLUX_CROSS_HOST:+--cross-file=cross-file.ini} \
    "-Dc_args=-Dg_variant_builder_init_static=g_variant_builder_init" \
    -Dintrospection=false \
    -Dgtk_doc=false \
    -Ddesktop_docs=false \
    -Ddebug_tools=false \
    -Dudev=disabled \
    -Dsystemd=disabled \
    -Dbuild_gtk4=true \
    -Dlegacy_library=true
ninja -C build

%post-build

%install
DESTDIR="$DESTDIR" ninja -C build install
