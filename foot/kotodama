[meta]
name = foot
version = 1.27.0
description = "Fast, lightweight Wayland terminal emulator"
license = MIT
size = 2

[source]
url = https://codeberg.org/dnkl/foot/archive/1.27.0.tar.gz
sha256 = 4e6131cc859ec6a36569f1978cf3617cc3836a681d13d228ded1b4885dab7770

[deps]
build = gcc meson ninja pkgconf wayland wayland-protocols libxkbcommon freetype fontconfig harfbuzz pixman fcft tllist scdoc
runtime = wayland libxkbcommon freetype fontconfig harfbuzz pixman

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build
cat > native-pkgconfig.sh << 'WRAPPER'
#!/bin/sh
unset PKG_CONFIG_LIBDIR
unset PKG_CONFIG_PATH
exec /usr/bin/pkg-config "$@"
WRAPPER
cat > native-file.ini << EOF
[binaries]
pkg-config = ['sh', '$(pwd)/native-pkgconfig.sh']
wayland-scanner = '/usr/bin/wayland-scanner'
EOF
if [ -n "$FLUX_CROSS_HOST" ]; then
cat > cross-file.ini << EOF
[host_machine]
system = 'linux'
cpu_family = 'x86_64'
cpu = 'x86_64'
endian = 'little'
[binaries]
c = '${CC:-gcc}'
ar = '${AR:-ar}'
strip = '${STRIP:-strip}'
pkg-config = 'pkg-config'
[properties]
sys_root = '${FLUX_CROSS_SYSROOT}'
pkg_config_libdir = ['${FLUX_CROSS_SYSROOT}/usr/lib/pkgconfig', '${FLUX_CROSS_SYSROOT}/usr/share/pkgconfig']
EOF
fi

%build
rm -rf build
meson setup build \
    --native-file=native-file.ini \
    --prefix=/usr \
    --buildtype=release \
    ${FLUX_CROSS_HOST:+--cross-file=cross-file.ini} \
    -Ddocs=disabled \
    -Dthemes=true
ninja -C build

%post-build

%install
DESTDIR="$DESTDIR" ninja -C build install
