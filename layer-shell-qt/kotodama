[meta]
name = layer-shell-qt
version = 6.3.4.1
description = "Qt component to allow applications to make use of the Wayland wlr-layer-shell protocol"
license = LGPL-2.1-or-later
size = 1

[source]
url = https://download.kde.org/stable/plasma/6.3.4/layer-shell-qt-6.3.4.tar.xz
sha256 = f80c983f48d3abefd6684ce93fc67368ce207f2160734d4e113a418c69a26346

[deps]
build = gcc cmake ninja pkgconf qt6-base qt6-wayland wayland wayland-protocols ecm
runtime = qt6-base qt6-wayland wayland

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build
# src/CMakeLists.txt links Qt::WaylandClientPrivate directly, but upstream's
# own find_package call never requests that component - it apparently relied
# on some now-changed Qt 6.8 behavior that auto-exposed it. Request it
# explicitly so the target actually gets defined.
sed -i 's/REQUIRED COMPONENTS WaylandClient Qml/REQUIRED COMPONENTS WaylandClient WaylandClientPrivate/' CMakeLists.txt
sed -i 's/add_subdirectory(declarative)/if(TARGET Qt6::Qml)\nadd_subdirectory(declarative)\nendif()/' src/CMakeLists.txt
sed -i '/add_subdirectory(tests)/d' CMakeLists.txt
if [ -n "$FLUX_CROSS_HOST" ]; then
cat > toolchain.cmake << EOF
set(CMAKE_SYSTEM_NAME Linux)
set(CMAKE_SYSTEM_PROCESSOR x86_64)
set(CMAKE_C_COMPILER ${CC})
set(CMAKE_CXX_COMPILER ${CXX})
set(CMAKE_SYSROOT ${FLUX_CROSS_SYSROOT})
set(CMAKE_FIND_ROOT_PATH ${FLUX_CROSS_SYSROOT})
set(CMAKE_FIND_ROOT_PATH_MODE_PROGRAM NEVER)
set(CMAKE_FIND_ROOT_PATH_MODE_LIBRARY ONLY)
set(CMAKE_FIND_ROOT_PATH_MODE_INCLUDE ONLY)
set(CMAKE_FIND_ROOT_PATH_MODE_PACKAGE ONLY)
EOF
fi

%build
rm -rf build
cmake -S . -B build \
    -GNinja \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DCMAKE_BUILD_TYPE=Release \
    ${FLUX_CROSS_HOST:+-DCMAKE_TOOLCHAIN_FILE=toolchain.cmake} \
    ${FLUX_CROSS_HOST:+-DQT_HOST_PATH=/usr} \
    ${FLUX_CROSS_HOST:+-DQT_HOST_PATH_CMAKE_DIR=/usr/lib/x86_64-linux-gnu/cmake} \
    -DQT_NO_PACKAGE_VERSION_CHECK=TRUE \
    -DBUILD_TESTING=OFF
cmake --build build

%post-build

%install
DESTDIR="$DESTDIR" cmake --install build
