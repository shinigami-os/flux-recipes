[meta]
name = mesa
version = 24.3.4
description = "Open-source OpenGL/Vulkan implementation"
license = MIT
size = 150

[source]
url = https://archive.mesa3d.org/mesa-24.3.4.tar.xz
sha256 = e641ae27191d387599219694560d221b7feaa91c900bcec46bf444218ed66025

[deps]
build = gcc meson ninja pkgconf python3 libdrm libglvnd libX11 libxcb xorgproto libXfixes libXxf86vm libXrender libXrandr libpciaccess expat zlib llvm libelf
runtime = libdrm libglvnd libX11 libxcb libXfixes libXxf86vm libXrender libXrandr expat zlib libelf

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build
LLVM_CONFIG_BIN="$(find /usr/lib/llvm-*/bin/llvm-config /usr/bin/llvm-config-* 2>/dev/null | sort -V | tail -1)"
cat > native-pkgconfig.sh << 'WRAPPER'
#!/bin/sh
unset PKG_CONFIG_LIBDIR
unset PKG_CONFIG_PATH
exec /usr/bin/pkg-config "$@"
WRAPPER
chmod +x native-pkgconfig.sh
cat > native-file.ini << EOF
[binaries]
wayland-scanner = '/usr/bin/wayland-scanner'
llvm-config = '${LLVM_CONFIG_BIN}'
pkg-config = ['sh', '$(pwd)/native-pkgconfig.sh']
EOF
if [ -n "$FLUX_CROSS_HOST" ]; then
cat > cross-file.ini << EOF
[host_machine]
system = 'linux'
cpu_family = 'x86_64'
cpu = 'x86_64'
endian = 'little'
[binaries]
c = '${CC:-gcc}'
cpp = '${CXX:-g++}'
ar = '${AR:-ar}'
strip = '${STRIP:-strip}'
pkg-config = 'pkg-config'
[properties]
sys_root = '${FLUX_CROSS_SYSROOT}'
pkg_config_libdir = ['${FLUX_CROSS_SYSROOT}/usr/lib/pkgconfig', '${FLUX_CROSS_SYSROOT}/usr/share/pkgconfig']
EOF
fi

%build
rm -rf build
LLVM_CONFIG_BIN="$(find /usr/lib/llvm-*/bin/llvm-config /usr/bin/llvm-config-* 2>/dev/null | sort -V | tail -1)"
export LLVM_CONFIG="$LLVM_CONFIG_BIN"
meson setup build \
    --native-file=native-file.ini \
    --prefix=/usr \
    --buildtype=release \
    ${FLUX_CROSS_HOST:+--cross-file=cross-file.ini} \
    -Dplatforms=wayland,x11 \
    -Dgallium-drivers=radeonsi,iris,crocus,nouveau,r600,softpipe,virgl,svga \
    -Dintel-clc=auto \
    -Dvulkan-drivers='' \
    -Dglx=dri \
    -Degl=enabled \
    -Dgbm=enabled \
    -Dgles1=disabled \
    -Dgles2=enabled \
    -Dllvm=enabled \
    -Dshared-llvm=enabled \
    -Dopengl=true \
    -Dglvnd=enabled \
    -Dgallium-opencl=disabled \
    -Dgallium-va=disabled \
    -Dgallium-vdpau=disabled \
    -Dgallium-xa=disabled \
    -Db_ndebug=true
ninja -C build

%post-build

%install
DESTDIR="$DESTDIR" ninja -C build install
