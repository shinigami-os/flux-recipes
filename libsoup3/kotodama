[meta]
name = libsoup3
version = 3.6.5
description = "HTTP client/server library for GNOME"
license = LGPL-2.0-or-later
size = 5

[source]
url = https://download.gnome.org/sources/libsoup/3.6/libsoup-3.6.5.tar.xz
sha256 = 6891765aac3e949017945c3eaebd8cc8216df772456dc9f460976fbdb7ada234

[deps]
build = gcc meson ninja pkgconf glib libxml2 sqlite nghttp2 libpsl zlib glib-networking
runtime = glib libxml2 sqlite nghttp2 libpsl zlib glib-networking

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build

%build
export CFLAGS="-O2 -pipe -march=x86-64-v2"
meson setup build --prefix=/usr --buildtype=release -Dtests=false -Dvapi=disabled -Ddocs=disabled
ninja -C build

%post-build

%install
DESTDIR="$DESTDIR" ninja -C build install
