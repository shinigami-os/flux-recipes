[meta]
name = qt6-tools
version = 6.11.1
description = "Qt6 developer tools (lupdate, lrelease, Qt6LinguistTools cmake package)"
license = GPL-3.0-only OR LGPL-3.0-only
size = 30

[source]
url = https://download.qt.io/archive/qt/6.11/6.11.1/submodules/qttools-everywhere-src-6.11.1.tar.xz
sha256 = 8e61835a679c93fa9c6065b142353c2071ba68e297898937c32a03777fcaf50d

[deps]
build = gcc cmake ninja pkgconf qt6-base qt6-declarative
runtime = qt6-base

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build
if [ -n "$FLUX_CROSS_HOST" ]; then
cat > toolchain.cmake << EOF
set(CMAKE_SYSTEM_NAME Linux)
set(CMAKE_SYSTEM_PROCESSOR x86_64)
set(CMAKE_C_COMPILER ${CC})
set(CMAKE_CXX_COMPILER ${CXX})
set(CMAKE_SYSROOT ${FLUX_CROSS_SYSROOT})
set(CMAKE_FIND_ROOT_PATH ${FLUX_CROSS_SYSROOT})
set(CMAKE_FIND_ROOT_PATH_MODE_PROGRAM NEVER)
set(CMAKE_FIND_ROOT_PATH_MODE_LIBRARY ONLY)
set(CMAKE_FIND_ROOT_PATH_MODE_INCLUDE ONLY)
set(CMAKE_FIND_ROOT_PATH_MODE_PACKAGE ONLY)
EOF
fi

%build
rm -rf build
cmake -S . -B build -G Ninja \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_INSTALL_LIBDIR=lib \
    -DCMAKE_CXX_FLAGS=-U_GLIBCXX_ASSERTIONS \
    ${FLUX_CROSS_HOST:+-DCMAKE_TOOLCHAIN_FILE=toolchain.cmake} \
    ${FLUX_CROSS_HOST:+-DQT_HOST_PATH=/usr} \
    ${FLUX_CROSS_HOST:+-DQT_HOST_PATH_CMAKE_DIR=/usr/lib/x86_64-linux-gnu/cmake} \
    ${FLUX_CROSS_HOST:+-DQT_NO_PACKAGE_VERSION_CHECK=TRUE} \
    -DFEATURE_assistant=OFF \
    -DFEATURE_designer=OFF \
    -DFEATURE_pixeltool=OFF \
    -DFEATURE_distancefieldgenerator=OFF \
    -DQT_BUILD_TESTS=OFF \
    -DQT_BUILD_EXAMPLES=OFF
cmake --build build

%post-build

%install
DESTDIR="$DESTDIR" cmake --install build
