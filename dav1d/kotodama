[meta]
name = dav1d
version = 1.5.3
description = "Small, fast AV1 decoder"
license = BSD-2-Clause
size = 3

[source]
url = git+https://code.videolan.org/videolan/dav1d#1.5.3
sha256 =

[deps]
build = gcc meson ninja pkgconf
runtime =

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build
cat > native-pkgconfig.sh << 'WRAPPER'
#!/bin/sh
unset PKG_CONFIG_LIBDIR
unset PKG_CONFIG_PATH
unset PKG_CONFIG_SYSROOT_DIR
exec /usr/bin/pkg-config "$@"
WRAPPER
cat > native-file.ini << EOF
[binaries]
pkg-config = ['sh', '$(pwd)/native-pkgconfig.sh']
EOF

%build
rm -rf build
meson setup build \
    --native-file=native-file.ini \
    --prefix=/usr \
    --buildtype=release \
    -Denable_asm=false \
    -Denable_tools=false \
    -Denable_tests=false
ninja -C build

%post-build

%install
DESTDIR="$DESTDIR" ninja -C build install
