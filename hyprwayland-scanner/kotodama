[meta]
name = hyprwayland-scanner
version = 0.4.6
description = "Hyprland implementation of wayland-scanner in and for C++"
license = BSD-3-Clause
size = 1

[source]
url = git+https://github.com/hyprwm/hyprwayland-scanner#v0.4.6
sha256 =

[deps]
build = gcc cmake ninja pkgconf pugixml
runtime =

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build

%build
cmake -S . -B build -G Ninja \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DCMAKE_BUILD_TYPE=Release
cmake --build build

%post-build

%install
DESTDIR="$DESTDIR" cmake --install build
