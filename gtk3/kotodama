[meta]
name = gtk3
version = 3.24.43
description = "GTK 3 widget toolkit"
license = LGPL-2.1-or-later
size = 40

[source]
url = https://download.gnome.org/sources/gtk+/3.24/gtk+-3.24.43.tar.xz
sha256 = 7e04f0648515034b806b74ae5d774d87cffb1a2a96c468cb5be476d51bf2f3c7

[deps]
build = gcc meson ninja pkgconf glib pango cairo gdk-pixbuf atk at-spi2-core libxkbcommon wayland wayland-protocols libepoxy
runtime = glib pango cairo gdk-pixbuf atk at-spi2-core libxkbcommon wayland libepoxy

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build
cat > native-pkgconfig.sh << 'WRAPPER'
#!/bin/sh
unset PKG_CONFIG_LIBDIR
unset PKG_CONFIG_PATH
exec /usr/bin/pkg-config "$@"
WRAPPER
cat > native-file.ini << EOF
[binaries]
pkg-config = ['sh', '$(pwd)/native-pkgconfig.sh']
wayland-scanner = '/usr/bin/wayland-scanner'
glib-compile-schemas = '/usr/bin/glib-compile-schemas'
glib-compile-resources = '/usr/bin/glib-compile-resources'
gdbus-codegen = '/usr/bin/gdbus-codegen'
EOF
if [ -n "$FLUX_CROSS_HOST" ]; then
cat > cross-file.ini << EOF
[host_machine]
system = 'linux'
cpu_family = 'x86_64'
cpu = 'x86_64'
endian = 'little'
[binaries]
c = '${CC:-gcc}'
ar = '${AR:-ar}'
strip = '${STRIP:-strip}'
pkg-config = 'pkg-config'
glib-compile-schemas = '/usr/bin/glib-compile-schemas'
glib-compile-resources = '/usr/bin/glib-compile-resources'
gdbus-codegen = '/usr/bin/gdbus-codegen'
[properties]
sys_root = '${FLUX_CROSS_SYSROOT}'
pkg_config_libdir = ['${FLUX_CROSS_SYSROOT}/usr/lib/pkgconfig']
EOF
fi

%build
rm -rf build
meson setup build \
    --native-file=native-file.ini \
    --prefix=/usr \
    --buildtype=release \
    ${FLUX_CROSS_HOST:+--cross-file=cross-file.ini} \
    -Dx11_backend=false \
    -Dwayland_backend=true \
    -Dbroadway_backend=false \
    -Dintrospection=false \
    -Ddemos=false \
    -Dexamples=false \
    -Dtests=false \
    -Dinstalled_tests=false \
    -Dman=false \
    -Dgtk_doc=false \
    -Dprint_backends=
ninja -C build

%post-build

%install
DESTDIR="$DESTDIR" ninja -C build install
