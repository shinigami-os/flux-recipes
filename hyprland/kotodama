[meta]
name = hyprland
version = 0.55.4
description = "A dynamic tiling Wayland compositor that does not sacrifice on its looks"
license = BSD-3-Clause
size = 120

[source]
url = git+https://github.com/hyprwm/Hyprland#v0.55.4
sha256 =

[deps]
build = gcc cmake ninja pkgconf hyprwayland-scanner aquamarine hyprlang hyprutils hyprcursor hyprgraphics hyprland-protocols hyprwire wayland wayland-protocols libxkbcommon libdrm pixman cairo pango libinput mesa libglvnd glib re2 muparser lcms2 libXcursor util-linux lua55 glslang libxcb xcb-util-wm xcb-util-errors
runtime = aquamarine hyprlang hyprutils hyprcursor hyprgraphics hyprwire wayland libxkbcommon libdrm pixman cairo pango libinput mesa libglvnd glib re2 muparser lcms2 libXcursor util-linux lua55 glslang libxcb xcb-util-wm xcb-util-errors

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build
# std::string + std::string_view concatenation is a C++26 libstdc++ addition
# not yet in GCC 14.2.0; force the string_view operands to std::string first
sed -i 's|getRuntimeDir() + "/" + instanceSignature + "/" + filename|getRuntimeDir() + "/" + std::string(instanceSignature) + "/" + std::string(filename)|' \
    hyprctl/src/main.cpp
# #embed is a C23/C++26 directive GCC 14.2.0 doesn't support; it's only used
# here to inject a comma-separated byte list into an array initializer, so
# generate that same byte list ourselves and #include it instead
python3 -c "
data = open('example/hyprland.lua', 'rb').read()
open('src/config/lua/hyprland.lua.inc', 'w').write(','.join(str(b) for b in data))
"
sed -i 's|#embed "\.\./\.\./\.\./example/hyprland\.lua"|#include "hyprland.lua.inc"|' \
    src/config/lua/DefaultConfig.hpp
# GCC 14.2.0's -std=gnu++26 fails to resolve the ternary's common type when
# one branch needs a user-defined conversion operator and the other is
# nullptr; make the conversion explicit instead of relying on it implicitly
sed -i 's|return m_connection ? \*m_connection : nullptr;|return m_connection ? static_cast<xcb_connection_t*>(*m_connection) : nullptr;|' \
    src/xwayland/XWM.hpp
sed -i 's|strToNumber<uint64_t>(std::string{"0x"} + value)|strToNumber<uint64_t>(std::string{"0x"} + std::string(value))|' \
    src/config/shared/parserUtils/ParserUtils.cpp
# insert_range is C++23 but, like append_range, only landed in libstdc++
# with GCC 15; rewrite with insert() + reverse iterators instead
sed -i 's|requestedModes\.insert_range(requestedModes\.end(), sortedModes \| std::views::reverse);|requestedModes.insert(requestedModes.end(), sortedModes.rbegin(), sortedModes.rend());|' \
    src/helpers/Monitor.cpp

%build
cmake --no-warn-unused-cli \
    -S . -B build -G Ninja \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_INSTALL_LIBDIR=lib \
    -DNO_SYSTEMD=ON
cmake --build build

%post-build

%install
DESTDIR="$DESTDIR" cmake --install build
# Kira exposes Hyprland through the Sleex session, not as a bare desktop
# entry - leaving this would put a second, unsupported option in the greeter
rm -f "$DESTDIR/usr/share/wayland-sessions/hyprland.desktop"
