[meta]
name = swww
version = 0.11.2
description = "A Solution to your Wayland Wallpaper Woes"
license = GPL-3.0-only
size = 30

[source]
url = git+https://github.com/LGFae/swww#v0.11.2
sha256 =

[deps]
build = gcc pkgconf wayland wayland-protocols libxkbcommon
runtime = wayland libxkbcommon

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build

%build
for _h in /home/*; do
    [ -x "$_h/.cargo/bin/cargo" ] && REAL_HOME="$_h" && break
done
export PATH="$PATH:$REAL_HOME/.cargo/bin"
export CARGO_HOME="$REAL_HOME/.cargo"
export RUSTUP_HOME="$REAL_HOME/.rustup"
cargo build --release --locked

%post-build

%install
install -Dm755 target/release/swww "$DESTDIR/usr/bin/swww"
install -Dm755 target/release/swww-daemon "$DESTDIR/usr/bin/swww-daemon"
