[meta]
name = glslang
version = 16.3.0
description = "Khronos reference GLSL/HLSL to SPIR-V compiler and validator"
license = BSD-3-Clause
size = 20

[source]
url = git+https://github.com/KhronosGroup/glslang#16.3.0
sha256 =

[deps]
build = gcc cmake ninja pkgconf python3
runtime =

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build

%build
cmake -S . -B build -G Ninja \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DCMAKE_BUILD_TYPE=Release \
    -DBUILD_SHARED_LIBS=ON \
    -DENABLE_OPT=0 \
    -DGLSLANG_TESTS=OFF \
    -DBUILD_EXTERNAL=OFF
cmake --build build

%post-build

%install
DESTDIR="$DESTDIR" cmake --install build
