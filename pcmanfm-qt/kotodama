[meta]
name = pcmanfm-qt
version = 2.1.0.2
description = "Qt port of PCManFM file manager"
license = GPL-2.0-or-later
size = 2

[source]
url = https://github.com/lxqt/pcmanfm-qt/releases/download/2.1.0/pcmanfm-qt-2.1.0.tar.xz
sha256 = e63486571dfa1bc476785f0d881e2138c736708009589c05a93ab24575e06b4f

[deps]
build = gcc cmake ninja pkgconf qt6-base qt6-tools libfm-qt layer-shell-qt
runtime = qt6-base libfm-qt layer-shell-qt

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build
sed -i 's|#include <xcb/xcb.h>||' pcmanfm/desktopwindow.h
sed -i '/#include <X11\/Xlib\.h>/d' pcmanfm/application.cpp pcmanfm/desktopwindow.cpp
perl -e '
print "typedef void xcb_connection_t;\n";
print "typedef unsigned int xcb_atom_t;\n";
print "typedef struct { xcb_atom_t atom; } xcb_intern_atom_reply_t;\n";
print "#define XCB_PROP_MODE_REPLACE 0\n";
print "static inline xcb_intern_atom_reply_t* xcb_intern_atom(xcb_connection_t*,int,int,const char*){return new xcb_intern_atom_reply_t{0};}\n";
print "static inline xcb_intern_atom_reply_t* xcb_intern_atom_reply(xcb_connection_t*,xcb_intern_atom_reply_t* c,void*){return c;}\n";
print "static inline void xcb_change_property(xcb_connection_t*,int,unsigned,xcb_atom_t,xcb_atom_t,int,int,const void*){}\n";
' > pcmanfm/xcb_stub.h
sed -i 's|#include <xcb/xcb.h>|#include "xcb_stub.h"|' pcmanfm/desktopwindow.cpp
perl -0777 -i -pe 's|        // set freedesktop\.org EWMH hints properly\n        if\(QGuiApplication::platformName\(\) == QStringLiteral\("xcb"\)\) \{.*?\n        \}\n||s' pcmanfm/desktopwindow.cpp
if [ -n "$FLUX_CROSS_HOST" ]; then
cat > toolchain.cmake << EOF
set(CMAKE_SYSTEM_NAME Linux)
set(CMAKE_SYSTEM_PROCESSOR x86_64)
set(CMAKE_C_COMPILER ${CC})
set(CMAKE_CXX_COMPILER ${CXX})
set(CMAKE_SYSROOT ${FLUX_CROSS_SYSROOT})
set(CMAKE_FIND_ROOT_PATH ${FLUX_CROSS_SYSROOT})
set(CMAKE_FIND_ROOT_PATH_MODE_PROGRAM NEVER)
set(CMAKE_FIND_ROOT_PATH_MODE_LIBRARY ONLY)
set(CMAKE_FIND_ROOT_PATH_MODE_INCLUDE ONLY)
set(CMAKE_FIND_ROOT_PATH_MODE_PACKAGE ONLY)
EOF
fi

%build
rm -rf build
cmake -S . -B build -G Ninja \
    -GNinja \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DCMAKE_BUILD_TYPE=Release \
    ${FLUX_CROSS_HOST:+-DCMAKE_TOOLCHAIN_FILE=toolchain.cmake} \
    ${FLUX_CROSS_HOST:+-DQT_HOST_PATH=/usr} \
    ${FLUX_CROSS_HOST:+-DQT_HOST_PATH_CMAKE_DIR=/usr/lib/x86_64-linux-gnu/cmake} \
    -DQT_NO_PACKAGE_VERSION_CHECK=TRUE \
    ${FLUX_CROSS_HOST:+-DQt6LinguistTools_DIR=/usr/lib/x86_64-linux-gnu/cmake/Qt6LinguistTools}
cmake --build build

%post-build

%install
DESTDIR="$DESTDIR" cmake --install build
