%install
fetch_ttf() {
    url="$1"
    sha256="$2"
    out="$3"
    curl -sL -o "$out" "$url"
    echo "$sha256  $out" | sha256sum -c - || exit 1
}
install -dm755 "$DESTDIR/usr/share/fonts/raleway"
fetch_ttf "https://github.com/google/fonts/raw/main/ofl/raleway/Raleway%5Bwght%5D.ttf" \
    8bbcc3eb8275c388f4bcd998832f8a4b943eadbaf6a595205312774b5951aefb \
    "$DESTDIR/usr/share/fonts/raleway/Raleway[wght].ttf"
