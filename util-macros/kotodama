[meta]
name = util-macros
version = 1.20.2
description = "X.Org autoconf macros"
license = MIT
size = 1

[source]
url = https://xorg.freedesktop.org/releases/individual/util/util-macros-1.20.2.tar.xz
sha256 = 9ac269eba24f672d7d7b3574e4be5f333d13f04a7712303b1821b2a51ac82e8e

[deps]
build = gcc make
runtime =

[build]
cflags = -O2 -pipe -march=x86-64-v2

%build
./configure \
    --host="${FLUX_CROSS_HOST:-}" \
    --prefix=/usr
make

%install
make DESTDIR="$DESTDIR" install
