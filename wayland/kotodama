[meta]
name = wayland
version = 1.25.0
description = "Wayland display server protocol and libraries"
license = MIT
size = 1

[source]
url = https://gitlab.freedesktop.org/wayland/wayland/-/releases/1.25.0/downloads/wayland-1.25.0.tar.xz
sha256 = c065f040afdff3177680600f249727e41a1afc22fccf27222f15f5306faa1f03

[deps]
build = gcc meson ninja pkgconf expat libffi
runtime = expat libffi

[build]
cflags = -O2 -pipe -march=x86-64-v2

%pre-build
sed -i \
    "s|scanner_dep = dependency('wayland-scanner', native: true, version: meson.project_version())|scanner_dep = dependency('wayland-scanner', native: true, required: false)|" \
    src/meson.build
sed -i \
    "s|wayland_scanner_for_build = find_program(scanner_dep.get_variable(pkgconfig: 'wayland_scanner'))|wayland_scanner_for_build = find_program('wayland-scanner', native: true)|" \
    src/meson.build
sed -i "/meson.override_find_program('wayland-scanner'/d" src/meson.build
cat > native-pkgconfig.sh << 'WRAPPER'
#!/bin/sh
unset PKG_CONFIG_LIBDIR
unset PKG_CONFIG_PATH
exec /usr/bin/pkg-config "$@"
WRAPPER
cat > native-file.ini << EOF
[binaries]
pkgconfig = ['sh', '$(pwd)/native-pkgconfig.sh']
wayland-scanner = '/usr/bin/wayland-scanner'
EOF
if [ -n "$FLUX_CROSS_HOST" ]; then
cat > cross-file.ini << EOF
[host_machine]
system = 'linux'
cpu_family = 'x86_64'
cpu = 'x86_64'
endian = 'little'
[binaries]
c = '${CC:-gcc}'
ar = '${AR:-ar}'
strip = '${STRIP:-strip}'
pkg-config = 'pkg-config'
[properties]
sys_root = '${FLUX_CROSS_SYSROOT}'
pkg_config_libdir = ['${FLUX_CROSS_SYSROOT}/usr/lib/pkgconfig']
EOF
fi

%build
meson setup build \
    --prefix=/usr \
    --buildtype=release \
    --native-file=native-file.ini \
    ${FLUX_CROSS_HOST:+--cross-file=cross-file.ini} \
    -Ddocumentation=false \
    -Dtests=false \
    -Ddtd_validation=false
ninja -C build

%post-build

%install
DESTDIR="$DESTDIR" ninja -C build install
