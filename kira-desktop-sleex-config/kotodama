[meta]
name = kira-desktop-sleex-config
version = 26.07-1
description = "Default Sleex desktop user configuration (skel, dotfiles)"
license = GPL-3.0-only
size = 3

[source]
url = git+https://github.com/shinigami-os/kira-desktop#v26.07-1
sha256 =

[deps]
build =
runtime =

[build]
cflags =

%pre-build

%build

%post-build

%install
install -dm755 "$DESTDIR/etc/skel/.config/kira-desktop"
echo "sleex" > "$DESTDIR/etc/skel/.config/kira-desktop/active-de"
echo "kira-default" > "$DESTDIR/etc/skel/.config/kira-desktop/current-theme"
cp -a "sleex/." "$DESTDIR/etc/skel/.config/"
install -dm755 "$DESTDIR/root/.config"
cp -a "sleex/." "$DESTDIR/root/.config/"

%post-install
for home in /home/*; do
    [ -d "$home" ] || continue
    username=$(basename "$home")
    mkdir -p "$home/.config/kira-desktop"
    echo "sleex" > "$home/.config/kira-desktop/active-de"
    echo "kira-default" > "$home/.config/kira-desktop/current-theme"
    cp -a /etc/skel/.config/. "$home/.config/"
    chown -R "$username:$username" "$home/.config/" 2>/dev/null || true
done
echo "[kira-desktop-sleex-config] Config installed. Log out and pick Sleex, or reboot."
